{
  "name": "astro-chensoul",
  "type": "module",
  "version": "1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro check && astro build && pagefind --site dist --glob \"posts/**/*.html\"",
    "preview": "astro preview --host --allowed-hosts=blog.chensoul.cc",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "pnpm exec prettier --check .",
    "format": "pnpm exec prettier --write .",
    "lint": "eslint .",
    "convert-to-webp": "node scripts/convert-to-webp.mjs",
    "spell": "pnpm dlx cspell --config cspell.yaml .",
    "md:check": "pnpm dlx markdownlint-cli2 ./content/posts/**",
    "md:fix": "pnpm dlx markdownlint-cli2 --fix ./content/posts/**"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.2",
    "@astrojs/rss": "4.0.17",
    "@expressive-code/plugin-collapsible-sections": "^0.41.3",
    "@expressive-code/plugin-line-numbers": "^0.41.2",
    "@tailwindcss/vite": "^4.1.8",
    "@zokki/astro-minify": "^1.1.0",
    "astro": "^6.0.0",
    "astro-compressor": "^1.0.0",
    "astro-expressive-code": "^0.41.2",
    "astro-mermaid": "^2.0.0",
    "dayjs": "^1.11.19",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.12.3",
    "photosuite": "0.2.1-beta",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-rewrite": "^4.0.2",
    "rehype-slug": "^6.0.0",
    "rehype-wrap-all": "^1.1.0",
    "remark-math": "^6.0.0",
    "strnum": "^2.2.0",
    "tailwindcss": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@minify-html/node": "0.18.1"
    }
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@critters-rs/astro": "^1.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/markdown-it": "^14.1.2",
    "eslint": "^10.0.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^17.0.0",
    "pagefind": "^1.3.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.33.1"
  }
}
