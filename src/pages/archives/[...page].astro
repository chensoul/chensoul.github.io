---
/**
 * 归档页
 *
 * @fileoverview 按年分组展示全部文章，顶部为分类与年份锚点链接；getStaticPaths 生成单页（pageSize 为全部文章数），实际列表由前端懒加载或一次性渲染。
 */
import Layout from "@/layouts/Layout.astro";
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import { SITE } from "@/config";
import { PostUtils } from "@/utils/postUtils";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const sortedPosts = PostUtils.sort(posts);
  return paginate(sortedPosts, { pageSize: sortedPosts.length });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const categories = PostUtils.getUniqueCategories(page.data);

const groupedByYear = PostUtils.groupBy(page.data, item =>
  new Date(item.data.updated ?? item.data.date).getFullYear()
);

const years = Object.keys(groupedByYear)
  .map(y => Number(y))
  .sort((a, b) => b - a);
---

<Layout title={`归档 | ${SITE.title}`}>
  <section class="archives-categories mb-4" aria-label="分类列表">
    <p class="archives-intro">
      按时间浏览全部文章，也可以先从分类进入。
    </p>
    <p class="mb-1 flex flex-wrap items-baseline gap-x-2 gap-y-1 text-base">
      <span class="opacity-80">分类：</span>
      {
        categories.map(({ category, categoryName, count }) => (
          <a href={`/categories/${category}`} class="text-sm hover:underline">
            {categoryName}（{count}）
          </a>
        ))
      }
    </p>
    <p class="flex flex-wrap items-baseline gap-x-2 gap-y-1 text-base">
      <span class="opacity-80">年份：</span>
      {
        years.map(year => (
          <a href={`#year-${year}`} class="text-sm hover:underline">
            {year}（{groupedByYear[year].length}）
          </a>
        ))
      }
    </p>
  </section>

  <section class="archives-by-year" aria-label="按年归档">
    {
      years.map(year => (
        <div id={`year-${year}`} class="archives-year mb-8" tabindex={-1}>
          <h2 class="mb-1 text-base">
            {year} ({groupedByYear[year].length})
          </h2>
          <ul class="mt-1 list-none space-y-1 pl-0 text-left">
            {groupedByYear[year].map(({ data, id, filePath }) => {
              const d = new Date(data.updated ?? data.date);
              const tz = data.timezone ?? SITE.timezone;
              const dateStr = PostUtils.getLocalDateString(d, tz);
              const dateText = dateStr.slice(5);
              const primaryCategory = data.categories?.[0];
              return (
                <li class="flex items-start gap-2 leading-6">
                  <span class="w-14 text-right text-sm tabular-nums opacity-80">
                    {dateText}
                  </span>
                  <span class="opacity-80">»</span>
                  <a
                    href={PostUtils.getPath(
                      id,
                      filePath,
                      true,
                      data.date,
                      data.timezone
                    )}
                    class="flex-1 text-sm hover:underline"
                  >
                    {data.title}
                  </a>
                  {primaryCategory && (
                    <a
                      href={`/categories/${primaryCategory}`}
                      class="archives-category"
                    >
                      {primaryCategory}
                    </a>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </section>
</Layout>

<style>
  .archives-intro {
    margin: 0 0 0.75rem;
    color: var(--text-secondary);
    font-size: 0.9375rem;
  }

  .archives-by-year ul {
    padding-left: 0;
  }

  /* 锚点滚动时留出顶栏高度，避免被 sticky header 遮住 */
  .archives-year {
    scroll-margin-top: 5rem;
  }

  .archives-category {
    align-self: start;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    background: var(--background-secondary);
    color: var(--text-secondary);
    font-size: 0.75rem;
    line-height: 1.5;
    text-decoration: none;
    white-space: nowrap;
  }

  .archives-category:hover {
    color: var(--accent);
    text-decoration: none;
  }
</style>
