---
/**
 * 搜索页
 *
 * @fileoverview 客户端使用 Pagefind 搜索文章，输入关键词后请求 /pagefind/pagefind.js 进行检索，结果展示标题、摘要与链接（最多 10 条）。
 *
 * 依赖：构建阶段需生成 pagefind 索引（如 Astro 或 CI 中执行 pagefind）；若加载失败则显示错误提示。
 */
import Layout from "../layouts/Layout.astro";

export const pageSlug = "search";
export const pageTitle = "搜索";
export const pageDescription = "搜索所有文章";
---

<Layout title={pageTitle} description={pageDescription} robots="noindex,follow">
  <div class="search-container">
    <div id="search">
      <div class="search-box">
        <input
          type="text"
          id="search-input"
          placeholder="输入关键词搜索..."
          autocomplete="off"
        />
        <button id="search-button">搜索</button>
      </div>
      <div id="search-results"></div>
    </div>
  </div>
</Layout>

<script is:inline>
  async function initSearchPage() {
    const searchInput = document.getElementById("search-input");
    const searchButton = document.getElementById("search-button");
    const resultsContainer = document.getElementById("search-results");
    if (!searchInput || !searchButton || !resultsContainer) return;
    if (searchInput.dataset.bound === "1") return;

    searchInput.dataset.bound = "1";

    const initialQuery =
      new URLSearchParams(window.location.search).get("q")?.trim() || "";

    let pagefind;
    let loadingPagefind = false;
    let pagefindReady = false;

    async function ensurePagefind() {
      if (pagefindReady || loadingPagefind) return pagefindReady;

      loadingPagefind = true;
      searchInput.placeholder = "正在加载搜索功能...";

      try {
        pagefind = await import("/pagefind/pagefind.js");
        await pagefind.init();
        pagefindReady = true;
        searchInput.placeholder = "搜索文章标题、内容...";
        searchInput.disabled = false;
        return true;
      } catch {
        resultsContainer.innerHTML =
          '<p class="error">搜索功能加载失败，请刷新页面重试</p>';
        searchInput.placeholder = "搜索功能加载失败";
        return false;
      } finally {
        loadingPagefind = false;
      }
    }

    async function performSearch() {
      const query = searchInput.value.trim();
      if (!query) {
        resultsContainer.innerHTML = "";
        return;
      }

      const ready = await ensurePagefind();
      if (!ready) return;

      resultsContainer.innerHTML = '<p class="loading">搜索中...</p>';

      try {
        const search = await pagefind.search(query);

        if (search.results.length === 0) {
          resultsContainer.innerHTML =
            '<p class="no-results">未找到「' + query + "」的相关结果</p>";
          return;
        }

        let html =
          '<p class="result-count">找到 ' +
          search.results.length +
          " 个结果</p>";
        html += '<ul class="results-list">';

        for (const result of search.results.slice(0, 10)) {
          const data = await result.data();
          html += '<li class="result-item">';
          html +=
            '<a href="' +
            data.url +
            '" class="result-title">' +
            (data.meta.title || "无标题") +
            "</a>";
          html += '<p class="result-excerpt">' + data.excerpt + "</p>";
          html += "</li>";
        }

        html += "</ul>";

        if (search.results.length > 10) {
          html +=
            '<p class="more-results">还有 ' +
            (search.results.length - 10) +
            " 个结果...</p>";
        }

        resultsContainer.innerHTML = html;
      } catch {
        resultsContainer.innerHTML = '<p class="error">搜索出错，请重试</p>';
      }
    }

    async function warmupSearch() {
      await ensurePagefind();
    }

    searchInput.disabled = false;
    searchInput.placeholder = "输入关键词搜索...";
    searchButton.addEventListener("click", performSearch);
    searchInput.addEventListener("keypress", e => {
      if (e.key === "Enter") performSearch();
    });
    searchInput.addEventListener("focus", warmupSearch, { once: true });
    searchInput.addEventListener("pointerdown", warmupSearch, { once: true });
    searchButton.addEventListener("pointerdown", warmupSearch, { once: true });

    if (initialQuery) {
      searchInput.value = initialQuery;
      await performSearch();
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSearchPage, {
      once: true,
    });
  } else {
    initSearchPage();
  }
  document.addEventListener("astro:page-load", initSearchPage);
</script>
