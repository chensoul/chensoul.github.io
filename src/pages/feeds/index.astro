---
/**
 * 聚合 / Feeds 页（友联博客最新文章聚合）
 *
 * @fileoverview 由 SITE.feeds.enabled 控制是否开放；构建时读取 public/data/feeds.json，
 * 使用 ListLayout 一次性渲染全部列表项。
 */
import fs from "node:fs";
import path from "node:path";
import Layout from "@/layouts/Layout.astro";
import ListLayout from "@/layouts/ListLayout.astro";
import Card from "@/components/Card.astro";
import { SITE } from "@/config";

export const pageSlug = "feeds";
export const pageTitle = `${SITE.feeds.navLabel} | ${SITE.title}`;

const feedsEnabled = SITE.feeds.enabled;

let feedItems: Array<{
  title: string;
  link: string;
  published: string;
  name?: string;
  blog_name?: string;
  category?: string | null;
  avatar?: string;
}> = [];
if (feedsEnabled) {
  try {
    const dataPath = path.join(process.cwd(), "public", "data", "feeds.json");
    if (fs.existsSync(dataPath)) {
      const data = JSON.parse(fs.readFileSync(dataPath, "utf-8"));
      feedItems = Array.isArray(data.items) ? data.items : [];
    }
  } catch {
    feedItems = [];
  }
}

const pageDescription = feedsEnabled
  ? "以下列表是使用程序定时从我关注的 RSS 订阅源抓取到的文章、视频和播客。"
  : "";
---

<Layout title={pageTitle} schemaType="CollectionPage" robots="noindex,follow">
  {
    !feedsEnabled ? (
      <ListLayout title={SITE.feeds.navLabel}>
        <p class="mb-0 text-sm leading-snug text-muted">
          本页暂未开放。若需展示友链博客的最新文章聚合，请在站点配置中开启
          <code>SITE.feeds.enabled</code> 并配置数据源。
        </p>
      </ListLayout>
    ) : (
      <ListLayout
        title={SITE.feeds.navLabel}
        description={pageDescription}
      >
        {feedItems.length === 0 ? (
          <p class="mb-0 text-sm text-muted">
            暂无内容。请确认已生成{" "}
            <code>public/data/feeds.json</code>（例如通过 CI 同步 RSS）。
          </p>
        ) : (
          <ul
            class="post-cards-list m-0 list-none p-0"
            aria-label="聚合文章列表"
          >
            {feedItems.map(item => (
              <Card
                mode="feed"
                title={item.title}
                link={item.link}
                published={item.published}
                blogName={item.name ?? item.blog_name}
                avatar={item.avatar}
              />
            ))}
          </ul>
        )}
      </ListLayout>
    )
  }
</Layout>
