---
/**
 * 订阅 / Feeds 页
 *
 * @fileoverview 从 SITE.feeds.dataSourceUrl 加载 JSON，客户端渲染列表并支持滚动加载更多。
 * 参考：https://github.com/achuanya/astro-lhasa
 */
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";

const clientData = {
  siteTimezone: SITE.timezone,
  fallbackOgImage: SITE.feeds.fallbackAvatarUrl,
  initialItemCount: SITE.feeds.initialCount,
  itemsPerPage: SITE.feeds.perPage,
  dataSourceUrl: SITE.feeds.dataSourceUrl || "",
};

// Critical CSS for dynamically loaded feeds cards (inlined to avoid critters pruning)
const feedsCriticalCSS = `.feeds-card-wrapper{margin-bottom:1rem}.feeds-card{display:flex;align-items:center;gap:.75rem;color:var(--text-primary)}.feeds-card-avatar-wrap{flex-shrink:0;display:block;width:40px;height:40px;overflow:hidden;border-radius:.375rem}.feeds-card img.feeds-card-avatar{display:block;width:40px!important;height:40px!important;min-width:40px;min-height:40px;max-width:40px!important;max-height:40px!important;object-fit:cover;border-radius:.375rem}.feeds-card-content{flex:1;min-width:0}.feeds-card-title{display:block;font-size:.875rem;font-weight:500;line-height:1.4;margin:0 0 .25rem;color:var(--accent);text-decoration:none;text-underline-offset:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}a.feeds-card-title:hover{text-decoration:underline}.feeds-card-meta{display:block;font-size:.875rem;margin-top:.125rem;opacity:.8;color:var(--text-secondary)}`;
---

<Layout
  title={`订阅 | ${SITE.title}`}
  description={`最新文章聚合（RSS Feeds）`}
>
  <div class="page-content feeds-page">
    <p class="feeds-intro mb-6 text-[var(--text-secondary)]">
      以下为我关注的的订阅聚合，数据来自 RSS
      定时抓取。若加载失败，请稍后重试或检查网络。
      {
        !clientData.dataSourceUrl && (
          <span class="mt-2 block">
            请在站点配置（<code>SITE.feeds.dataSourceUrl</code>）中填写聚合 JSON
            地址以启用列表。
          </span>
        )
      }
    </p>

    <div
      id="feeds-data-json-container"
      data-json={JSON.stringify(clientData)}
      class="hidden"
      aria-hidden="true"
    >
    </div>

    <div id="feeds-loading" class="feeds-loading">加载中…</div>
    <div id="feeds-error" class="feeds-message hidden">
      加载 Feeds 失败，请稍后重试或检查网络连接。
    </div>
    <div id="feeds-no-content" class="feeds-message hidden">暂无内容。</div>

    <ul
      id="feeds-list"
      class="feeds-list mt-4 list-none pl-0"
      aria-label="文章列表"
    >
    </ul>
    <div
      id="load-more-trigger"
      class="load-more-trigger flex h-8 items-center justify-center text-sm text-[var(--text-secondary)]"
      style="display: none"
      aria-hidden="true"
    >
      <span>加载更多</span>
    </div>
  </div>

  <!-- Critical CSS for dynamically loaded feeds cards (inlined to avoid critters pruning) -->
  <div set:html={`<style>${feedsCriticalCSS}</style>`} />

  <script is:inline type="module" src="/feeds.js"></script>
</Layout>
