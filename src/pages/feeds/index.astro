---
/**
 * 邻居 / Feeds 页（友联博客最新文章聚合）
 *
 * @fileoverview 由 SITE.feeds.enabled 控制是否开放；构建时若存在 public/data/feeds.json 则用 FeedItem 渲染首屏，剩余条目由客户端滚动加载。
 */
import fs from "node:fs";
import path from "node:path";
import Layout from "@/layouts/Layout.astro";
import FeedItem from "@/components/FeedItem.astro";
import { SITE } from "@/config";

export const pageSlug = "feeds";
export const pageTitle = `${SITE.feeds.navLabel} | ${SITE.title}`;

const feedsEnabled = SITE.feeds.enabled;

let feedItems: Array<{
  title: string;
  link: string;
  published: string;
  name?: string;
  blog_name?: string;
  category?: string | null;
  avatar?: string;
}> = [];
if (feedsEnabled) {
  try {
    const dataPath = path.join(process.cwd(), "public", "data", "feeds.json");
    if (fs.existsSync(dataPath)) {
      const data = JSON.parse(fs.readFileSync(dataPath, "utf-8"));
      feedItems = Array.isArray(data.items) ? data.items : [];
    }
  } catch {
    feedItems = [];
  }
}

const initialCount = SITE.feeds.initialCount;
const initialItems = feedItems.slice(0, initialCount);
const hasInitialItems = feedItems.length > 0;

const clientData = {
  fallbackOgImage: SITE.feeds.fallbackAvatarUrl,
  cosHost: SITE.feeds.cosHost || "",
  initialItemCount: initialCount,
  itemsPerPage: SITE.feeds.perPage,
  dataSourceUrl: SITE.feeds.dataSourceUrl || "",
  hasInitialItems,
  items: feedItems,
};
---

<Layout title={pageTitle} schemaType="CollectionPage" robots="noindex,follow">
  <div class="feeds-page">
    <h2>邻居</h2>
    {
      !feedsEnabled ? (
        <p class="page-description">
          本页暂未开放。若需展示邻居博客的最新文章聚合，请在站点配置中开启
          <code>SITE.feeds.enabled</code> 并配置数据源。
        </p>
      ) : (
        <>
          <p class="page-description">
            以下列表是使用程序定时从我关注的 RSS
            订阅源抓取到的文章、视频和播客，我可以第一时间查看是否有更新，并阅读、观看和收听。
            {!clientData.dataSourceUrl && (
              <span class="block">
                请在站点配置（<code>SITE.feeds.dataSourceUrl</code>）中填写聚合
                JSON 地址以启用列表。
              </span>
            )}
          </p>

          <div
            id="feeds-data-json-container"
            data-json={JSON.stringify(clientData)}
            class="hidden"
            aria-hidden="true"
          />

          <div
            id="feeds-loading"
            class="feeds-loading"
            class:list={[hasInitialItems && "hidden"]}
          >
            加载中…
          </div>
          <div id="feeds-error" class="feeds-message hidden">
            加载失败，请稍后重试或检查网络连接。
          </div>
          <div id="feeds-no-content" class="feeds-message hidden">
            暂无内容。
          </div>

          <ul
            id="feeds-list"
            class="feeds-list"
            aria-label="文章列表"
          >
            {initialItems.map((item, index) => (
              <FeedItem
                title={item.title}
                link={item.link}
                published={item.published}
                blogName={item.name ?? item.blog_name}
                category={item.category ?? undefined}
                avatar={item.avatar}
                priority={index === 0}
              />
            ))}
          </ul>
          <div
            id="load-more-trigger"
            class="load-more-trigger"
            style="display: none"
            aria-hidden="true"
          >
            <span>加载更多</span>
          </div>

          <script is:inline type="module" src="/feeds.js" />
        </>
      )
    }
  </div>
</Layout>
