---
/**
 * Wiki 知识库列表
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import { SITE } from "@/config";
import { PostUtils } from "@/utils/postUtils";

export const pageSlug = "wiki";
export const pageTitle = `Wiki | ${SITE.title}`;

const sorted = PostUtils.sort(await getCollection("wiki"));
---

<Layout title={pageTitle}>
  <h1>Wiki</h1>
  <p class="mt-2 mb-6 text-sm leading-snug text-pretty text-muted">
    主题索引与长期维护的笔记条目。
  </p>

  <ul class="post-cards-list m-0 list-none p-0" aria-label="Wiki 列表">
    {
      sorted.map(post => (
        <Card openInNewTab={false} dateFormat="absolute" {...post} />
      ))
    }
  </ul>
</Layout>
