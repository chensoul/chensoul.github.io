---
/**
 * 分类详情页
 *
 * @fileoverview 展示某一分类下的文章列表；getStaticPaths 为每个分类生成分页路由，页面内用 Card 列表 + 可选懒加载展示。
 */
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import TaxonomySummary from "@/components/TaxonomySummary.astro";
import { PostUtils, slugifyStr } from "@/utils/postUtils";
import { SITE } from "@/config";

export const pageTitle = `分类 | ${SITE.title}`;
export const pageDescription = SITE.description;

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const publishedPosts = PostUtils.getPublishedPosts(
    await getCollection("blog")
  );

  const categories = PostUtils.getUniqueCategories(publishedPosts);

  return categories.flatMap(({ category, categoryName }) => {
    const categoryPosts = PostUtils.sort(
      publishedPosts.filter(post =>
        post.data.categories.some(
          postCategory => slugifyStr(postCategory) === category
        )
      )
    );
    return paginate(categoryPosts, {
      params: { category },
      props: { categoryName },
      pageSize: categoryPosts.length,
    });
  });
}

// 从 Astro.props 中解构获取分页数据和分类显示名称
const { page, categoryName } = Astro.props;
const categoryParam = String(Astro.params.category ?? "");
const cardListKind = categoryParam === "weekly" ? "weekly" : "article";
const tagCount = new Map<string, { tagName: string; count: number }>();
page.data.forEach(post => {
  post.data.tags.forEach(tag => {
    const slug = slugifyStr(tag);
    const existing = tagCount.get(slug);
    if (existing) {
      existing.count += 1;
    } else {
      tagCount.set(slug, { tagName: tag, count: 1 });
    }
  });
});
const topTags = Array.from(tagCount.entries())
  .sort(
    (a, b) =>
      b[1].count - a[1].count ||
      a[1].tagName.localeCompare(b[1].tagName, "zh-CN")
  )
  .slice(0, 6);
const relatedTags = topTags.map(([tag, { tagName, count }]) => ({
  href: `/tags/${tag}`,
  label: tagName,
  count,
}));
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="mb-6">
    <div class="breadcrumb" aria-label="面包屑导航">
      <a href="/">首页</a>
      <span class="breadcrumb-separator">/</span>
      <a href="/categories">分类</a>
      <span class="breadcrumb-separator">/</span>
      <span>{categoryName}</span>
    </div>
    <h1 class="my-2 text-3xl font-semibold tracking-tight">{categoryName}</h1>
    <TaxonomySummary title="相关标签" items={relatedTags} />
  </section>
  <ul id="category-posts-list" class="post-cards-list m-0 list-none p-0">
    {
      page.data.map((data, i) => (
        <Card
          {...data}
          listKind={cardListKind}
          hidden={i >= SITE.postPerIndex}
          dateFormat="absolute"
        />
      ))
    }
  </ul>
  {/* 懒加载哨兵元素：用于 IntersectionObserver 检测滚动位置 */}
  <div
    id="category-posts-sentinel"
    data-init={SITE.postPerIndex}
    data-chunk={SITE.postPerIndex}
  >
  </div>
</Layout>

{SITE.lazyListJsUrl && <script is:inline src={SITE.lazyListJsUrl} />}
<script is:inline>
  let bootTimer;
  function boot() {
    if (typeof window.setupLazyList !== "function") return false;
    if (bootTimer) {
      clearTimeout(bootTimer);
      bootTimer = undefined;
    }
    window.setupLazyList({
      sentinelId: "category-posts-sentinel",
      itemSelector: "#category-posts-list > li",
    });
    return true;
  }
  function scheduleBoot() {
    if (boot()) return;
    if (bootTimer) clearTimeout(bootTimer);
    bootTimer = setTimeout(scheduleBoot, 120);
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleBoot, { once: true });
  } else {
    scheduleBoot();
  }
  window.addEventListener("load", scheduleBoot);
  document.addEventListener("astro:page-load", scheduleBoot);
</script>
