---
/**
 * 分类索引页
 *
 * @fileoverview 显示所有分类及其文章数量；支持懒加载分批展示。
 */
import { getAllBlogLike } from "@/utils/contentCollections";
import Layout from "@/layouts/Layout.astro";
import {
  getCategoryImageUrl,
  getCategoryOrder,
  PostUtils,
} from "@/utils/postUtils";
import { SITE } from "@/config";

export const pageSlug = "categories";
export const pageTitle = `分类 | ${SITE.title}`;

const publishedPosts = PostUtils.getPublishedPosts(await getAllBlogLike());
const sortedPosts = PostUtils.sort(publishedPosts);

const categories = PostUtils.getUniqueCategories(publishedPosts).sort(
  (a, b) =>
    getCategoryOrder(a.category) - getCategoryOrder(b.category) ||
    a.categoryName.localeCompare(b.categoryName, "zh-CN")
);

const categoryLatestPost = new Map<string, string>();
categories.forEach(({ category, categoryName }) => {
  const latestPost = sortedPosts.find(post =>
    post.data.categories.some(postCategory => postCategory === category)
  );
  if (latestPost) {
    categoryLatestPost.set(categoryName, latestPost.data.title);
  }
});
---

<Layout title={pageTitle}>
  <h1>分类</h1>
  <ul
    id="categories-root"
    class="m-0 grid list-none grid-cols-1 gap-5 p-0 sm:grid-cols-2"
    aria-label="分类列表"
  >
    {
      categories.map(({ category, categoryName, count }, i) => (
        <li class:list={[{ hidden: i >= SITE.postPerIndex }]}>
          <a
            href={`/categories/${category}`}
            aria-label={`查看 ${categoryName} 分类`}
            class="relative block overflow-hidden rounded-lg border border-border text-white no-underline shadow-sm transition-shadow hover:shadow-md"
          >
            <div class="relative aspect-video w-full overflow-hidden">
              {getCategoryImageUrl(category) ||
              getCategoryImageUrl(categoryName) ? (
                <img
                  src={
                    getCategoryImageUrl(category) ||
                    getCategoryImageUrl(categoryName)
                  }
                  alt={`${categoryName} 分类缩略图`}
                  class="block h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="min-h-[120px] w-full bg-gradient-to-br from-background-secondary to-accent/15" />
              )}
              <div
                class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"
                aria-hidden="true"
              />
              <div class="absolute right-0 bottom-0 left-0 z-[1] px-4 py-4 text-left">
                <span class="mb-1 block text-sm opacity-90">
                  {categoryName}（{count}篇）
                </span>
                <h3 class="m-0 text-base leading-snug font-semibold text-white">
                  {categoryLatestPost.get(categoryName) || categoryName}
                </h3>
              </div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
  <div
    id="categories-sentinel"
    data-init={SITE.postPerIndex}
    data-chunk={SITE.postPerIndex}
  >
  </div>
</Layout>

{SITE.lazyListJsUrl && <script is:inline src={SITE.lazyListJsUrl} />}
<script is:inline>
  let bootTimer;
  function boot() {
    if (typeof window.setupLazyList !== "function") return false;
    if (bootTimer) {
      clearTimeout(bootTimer);
      bootTimer = undefined;
    }
    window.setupLazyList({
      sentinelId: "categories-sentinel",
      itemSelector: "#categories-root > li",
    });
    return true;
  }
  function scheduleBoot() {
    if (boot()) return;
    if (bootTimer) clearTimeout(bootTimer);
    bootTimer = setTimeout(scheduleBoot, 120);
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleBoot, { once: true });
  } else {
    scheduleBoot();
  }
  window.addEventListener("load", scheduleBoot);
  document.addEventListener("astro:page-load", scheduleBoot);
</script>
