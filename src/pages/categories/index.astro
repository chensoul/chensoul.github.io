---
/**
 * 分类索引页
 *
 * @fileoverview 显示所有分类及其文章数量
 *
 * 核心逻辑：
 * 1. 获取所有分类（使用 getUniqueCategories）
 * 2. 获取每个分类的最新文章标题（用于显示）
 * 3. 显示分类封面图、名称、文章数量
 * 4. 支持懒加载分页（按配置注入 lazy-list 脚本）
 * 5. 悬停效果：图片放大
 *
 * 视觉设计：
 * - 卡片式布局（移动端单列，桌面端双列）
 * - 16:9 宽高比的封面图
 * - 渐变遮罩 + 文字叠加
 *
 * 依赖关系：
 * - 被 /categories 路径访问
 * - 使用分类元信息获取封面图
 */

import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import {
  getCategoryImageUrl,
  getCategoryOrder,
  PostUtils,
} from "@/utils/postUtils";
import { SITE } from "@/config";

export const pageSlug = "categories";
export const pageTitle = `分类 | ${SITE.title}`;

// 获取所有已公开文章并排序
const publishedPosts = PostUtils.getPublishedPosts(await getCollection("blog"));
const sortedPosts = PostUtils.sort(publishedPosts);

// 获取所有分类
const categories = PostUtils.getUniqueCategories(publishedPosts).sort(
  (a, b) =>
    getCategoryOrder(a.category) - getCategoryOrder(b.category) ||
    a.categoryName.localeCompare(b.categoryName, "zh-CN")
);

/**
 * 获取每个分类的最新文章标题
 *
 * 用于在分类卡片上显示该分类的最新文章标题
 */
const categoryLatestPost = new Map<string, string>();
categories.forEach(({ category, categoryName }) => {
  const latestPost = sortedPosts.find(post =>
    post.data.categories.some(postCategory => postCategory === category)
  );
  if (latestPost) {
    categoryLatestPost.set(categoryName, latestPost.data.title);
  }
});
---

<Layout title={pageTitle}>
  <h2>分类</h2>
  <ul class="categories-grid" aria-label="分类列表">
    {
      categories.map(({ category, categoryName, count }, i) => (
        <li class:list={["categories-item", { hidden: i >= SITE.postPerIndex }]}>
          <a
            href={`/categories/${category}`}
            aria-label={`查看 ${categoryName} 分类`}
            class="categories-card"
          >
            <div class="categories-card-image" style="aspect-ratio: 16 / 9;">
              {getCategoryImageUrl(category) ||
              getCategoryImageUrl(categoryName) ? (
                <img
                  src={
                    getCategoryImageUrl(category) ||
                    getCategoryImageUrl(categoryName)
                  }
                  alt={`${categoryName} 封面图`}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="categories-card-placeholder" />
              )}
            </div>
            <div class="categories-card-overlay" />
            <div class="categories-card-content">
              <span class="categories-card-name">
                {categoryName}（{count}篇）
              </span>
              <h3 class="categories-card-latest">
                {categoryLatestPost.get(categoryName) || categoryName}
              </h3>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
  <div
    id="categories-sentinel"
    data-init={SITE.postPerIndex}
    data-chunk={SITE.postPerIndex}
  >
  </div>
</Layout>
