---
/**
 * 归档页
 *
 * @fileoverview 按年分组展示全部文章，顶部为分类与年份锚点链接；getStaticPaths 生成单页（pageSize 为全部文章数），实际列表由前端懒加载或一次性渲染。
 */
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import { SITE } from "@/config";
import { PostUtils } from "@/utils/postUtils";
import TaxonomySummary from "@/components/TaxonomySummary.astro";

export const pageSlug = "posts";
export const pageTitle = `归档 | ${SITE.title}`;

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const sortedPosts = PostUtils.sort(posts);
  return paginate(sortedPosts, { pageSize: sortedPosts.length });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const categories = PostUtils.getUniqueCategories(page.data);

const groupedByYear = PostUtils.groupBy(page.data, item =>
  new Date(item.data.updated ?? item.data.date).getFullYear()
);

const years = Object.keys(groupedByYear)
  .map(y => Number(y))
  .sort((a, b) => b - a);

const yearsWithCounts = years.map(year => ({
  year,
  count: groupedByYear[year].length,
}));

const categoryItems = categories.map(({ category, categoryName, count }) => ({
  href: `/categories/${category}`,
  label: categoryName,
  count,
}));

const yearItems = yearsWithCounts.map(({ year, count }) => ({
  href: `#year-${year}`,
  label: String(year),
  count,
}));
---

<Layout title={pageTitle} robots="noindex,follow">
  <h2>归档</h2>
  <section
    class="archive-taxonomy my-5 flex flex-col gap-4 md:my-8"
    aria-label="分类列表"
  >
    <TaxonomySummary title="分类" items={categoryItems} />
    <TaxonomySummary title="年份" items={yearItems} />
  </section>

  <section class="flex flex-col gap-8" aria-label="按年归档">
    {
      years.map(year => (
        <div class="archive-year-section" id={`year-${year}`} tabindex={-1}>
          <h2 class="mb-4 border-b border-[var(--border)] pb-2">
            {year} ({groupedByYear[year].length})
          </h2>
          <ul class="post-cards-list m-0 list-none p-0">
            {groupedByYear[year].map(post => (
              <Card {...post} openInNewTab={false} dateFormat="absolute" />
            ))}
          </ul>
        </div>
      ))
    }
  </section>
</Layout>

<style>
  .archive-taxonomy :global(.taxonomy-summary) {
    margin: 0;
  }

  @media (min-width: 1024px) {
    .archive-taxonomy {
      width: calc(100% + 5rem);
      max-width: none;
      margin-right: -5rem;
    }
  }

  /* 与站点吸顶顶栏对齐，避免 #year-… 锚点滚入后被遮挡 */
  .archive-year-section {
    scroll-margin-top: calc(var(--site-header-sticky-offset) + 1rem);
  }
</style>
