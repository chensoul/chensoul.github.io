---
/**
 * 404 错误页
 *
 * @fileoverview 显示当用户访问不存在的页面时
 *
 * 核心逻辑：
 * 1. 显示 404 提示信息
 * 2. 鼠标悬停时显示动画图片（从静态图切换到 GIF）
 * 3. 提供返回首页的按钮
 *
 * 依赖关系：
 * - 当路由匹配失败时自动显示
 * - 文案与图片路径直接写在本页
 */

import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";

export const pageSlug = "404";
export const pageTitle = `404 Not Found | ${SITE.title}`;
export const pageDescription = SITE.description;

const notFoundStaticImage = "https://cos.lhasa.icu/StylePictures/404.webp";
const notFoundAnimatedImage = "https://cos.lhasa.icu/StylePictures/404.gif";
const notFoundTitle = "404，您访问的页面不存在～";
---

<Layout title={pageTitle} description={pageDescription}>
  <div
    class="flex flex-col items-center justify-center px-4 py-10 text-center"
  >
    <div
      id="image-container"
      class="relative mx-auto mb-6 w-full max-w-md cursor-pointer overflow-hidden rounded-xl shadow-sm"
    >
      <img
        id="static-image"
        src={notFoundStaticImage}
        alt="404 Not Found"
        loading="eager"
        decoding="async"
        class="block h-auto w-full"
      />
      <img
        id="animated-image"
        src={notFoundAnimatedImage}
        alt="404 Not Found"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 hidden h-full w-full object-cover"
      />
    </div>
    <p class="mb-6 text-lg text-[var(--text-secondary)]">{notFoundTitle}</p>
    <a
      href="/"
      class="text-base font-medium text-[var(--accent)] no-underline hover:underline"
    >
      回到首页 >>
    </a>
  </div>
</Layout>

<script>
  function initNotFoundImage() {
    const container = document.getElementById("image-container");
    const staticImage = document.getElementById("static-image");
    const animatedImage = document.getElementById("animated-image");

    if (!container || !staticImage || !animatedImage) return;
    if (container.dataset.bound === "1") return;

    container.dataset.bound = "1";

    // 鼠标悬停时显示动画
    container.addEventListener("mouseenter", () => {
      staticImage.style.display = "none";
      animatedImage.style.display = "block";
    });

    // 鼠标离开时显示静态图片
    container.addEventListener("mouseleave", () => {
      staticImage.style.display = "block";
      animatedImage.style.display = "none";
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNotFoundImage, {
      once: true,
    });
  } else {
    initNotFoundImage();
  }
  document.addEventListener("astro:page-load", initNotFoundImage);
</script>
