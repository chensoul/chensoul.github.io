---
/**
 * 周报列表
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ListLayout from "@/layouts/ListLayout.astro";
import Card from "@/components/Card.astro";
import { SITE } from "@/config";
import { PostUtils } from "@/utils/postUtils";

export const pageSlug = "briefs";
export const pageTitle = `周报 | ${SITE.title}`;

const sorted = PostUtils.sort(await getCollection("briefs"));
---

<Layout title={pageTitle}>
  <ListLayout
    title="周报"
    description="每周开发进展、工具尝试与阶段性想法。"
  >
    <ul class="post-cards-list m-0 list-none p-0" aria-label="周报列表">
      {
        sorted.map(post => (
          <Card
            openInNewTab={false}
            listKind="weekly"
            dateFormat="absolute"
            {...post}
          />
        ))
      }
    </ul>
  </ListLayout>
</Layout>
