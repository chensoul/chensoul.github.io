---
/**
 * 首页
 *
 * @fileoverview 聚合站点入口：最近博客仅 `posts` 集合；最近周报仅 `briefs` 集合。
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import { PostUtils } from "@/utils/postUtils";
import { SITE } from "@/config";

/** 与 /og/index.png 一致 */
export const pageSlug = "index";
export const pageTitle = SITE.title;
export const pageDescription = SITE.description;

const latestPosts = PostUtils.sort(await getCollection("posts")).slice(
  0,
  SITE.postPerIndex
);
const lifePosts = PostUtils.sort(await getCollection("briefs")).slice(0, 6);
---

<Layout title={pageTitle} description={pageDescription}>
  <section
    class="flex w-full min-w-0 flex-col gap-12 md:flex-row md:items-start md:gap-x-8 md:gap-y-0 lg:gap-x-10"
  >
    <div class="min-w-0 md:basis-[52%] lg:basis-[52%]">
      <header class="mb-2.5">
        <h3 class="mt-0 mb-1">最近博客</h3>
        <p class="mt-1 mb-0 text-sm leading-snug text-pretty text-muted">
          仅包含发布在博客目录下的长文（技术、生活等）。
          <a href="/posts" class="text-accent no-underline hover:underline">
            查看全部
          </a>
        </p>
      </header>
      <ul class="post-cards-list m-0 list-none p-0">
        {latestPosts.map(post => <Card openInNewTab={false} {...post} />)}
      </ul>
    </div>

    <aside class="min-w-0 md:basis-[48%] lg:basis-[48%]">
      <header class="mb-2.5">
        <h3 class="mt-0 mb-1">最近周报</h3>
        <p class="mt-1 mb-0 text-sm leading-snug text-pretty text-muted">
          记录每周开发进展、工具尝试和一些阶段性想法。
          <a href="/briefs" class="text-accent no-underline hover:underline">
            查看全部
          </a>
        </p>
      </header>
      <ul class="post-cards-list m-0 list-none p-0">
        {
          lifePosts.map(post => (
            <Card openInNewTab={false} listKind="weekly" {...post} />
          ))
        }
      </ul>
    </aside>
  </section>
</Layout>
