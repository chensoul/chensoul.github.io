---
/**
 * 首页
 *
 * @fileoverview 聚合站点入口：首屏介绍、主题入口、精选文章、最近更新与周报入口。
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import { PostUtils } from "@/utils/postUtils";
import { SITE } from "@/config";

/** 与 /og/index.png 一致 */
export const pageSlug = "index";
export const pageTitle = SITE.title;
export const pageDescription =
  "记录 Java、Spring、AI 编码工具、架构与个人周报的博客。这里可以快速浏览最近更新和最新周报。";

const publishedPosts = PostUtils.getPublishedPosts(await getCollection("blog"));
const sortedPosts = PostUtils.sort(publishedPosts);

const latestPosts = sortedPosts.slice(0, 6);
const lifePosts = PostUtils.getPostsByCategory(sortedPosts, "weekly").slice(
  0,
  6
);
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="home-section">
    <div class="home-column">
      <div class="section-header">
        <div>
          <h2 class="section-title">最近文章</h2>
          <p class="section-description">
            优先展示最近更新的技术文章、知识库条目和翻译内容。
          </p>
        </div>
      </div>
      <ul class="post-list">
        {latestPosts.map(post => <Card variant="h3" {...post} />)}
      </ul>
      <div class="section-action action-mobile">
        <LinkButton href="/posts" class="text-link">
          查看全部文章
        </LinkButton>
      </div>
    </div>

    <aside class="home-column">
      <div class="section-header">
        <div>
          <h2 class="section-title">最近周报</h2>
          <p class="section-description">
            记录每周的开发进展、工具尝试和一些阶段性想法。
          </p>
        </div>
      </div>
      <div class="weekly-list">
        {
          lifePosts.map(post => (
            <a
              class="weekly-item"
              href={PostUtils.getPath(
                post.id,
                post.filePath,
                true,
                post.data.date,
                post.data.timezone
              )}
            >
              <h3 class="weekly-title">
                {post.data.title}
              </h3>
              <p class="weekly-description">
                {post.data.description?.trim() ||
                  PostUtils.getDescription(post.body ?? "")}
              </p>
            </a>
          ))
        }
      </div>
      <div class="section-action">
        <LinkButton href="/categories/weekly" class="text-link">
          查看全部周报
        </LinkButton>
      </div>
    </aside>
  </section>
</Layout>
