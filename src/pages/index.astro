---
/**
 * 首页
 *
 * @fileoverview 聚合站点入口：首屏介绍、主题入口、精选文章、最近更新与周报入口。
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import { PostUtils } from "@/utils/postUtils";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const sortedPosts = PostUtils.sort(posts);

const latestPosts = sortedPosts.slice(0, SITE.postPerIndex);
const lifePosts = PostUtils.getPostsByCategory(sortedPosts, "weekly").slice(
  0,
  4
);
---

<Layout
  title={SITE.title}
  description="记录 Java、Spring、AI 编码工具、架构与个人周报的博客。这里可以快速浏览最近更新和最新周报。"
>
  <section class="home-split">
    <div class="home-main-panel">
      <div class="home-section-head">
        <h2>最近文章</h2>
        <div class="home-section-head-action home-section-head-action--mobile">
          <LinkButton
            href="/posts"
            class="home-section-link inline-flex items-center gap-1.5 border-0 bg-transparent px-0 py-0 text-sm text-[var(--accent)] no-underline outline-[var(--accent)] transition-colors hover:text-[var(--accent-dark)] focus-visible:outline-2 focus-visible:outline-offset-2"
          >
            查看全部文章
          </LinkButton>
        </div>
      </div>
      <ul class="home-card-list">
        {latestPosts.map(post => <Card variant="h3" {...post} />)}
      </ul>
      <div class="home-section-action home-section-action--desktop">
        <LinkButton
          href="/posts"
          class="home-section-link inline-flex items-center gap-1.5 border-0 bg-transparent px-0 py-0 text-sm text-[var(--accent)] no-underline outline-[var(--accent)] transition-colors hover:text-[var(--accent-dark)] focus-visible:outline-2 focus-visible:outline-offset-2"
        >
          查看全部文章
        </LinkButton>
      </div>
    </div>

    <aside class="home-side-panel">
      <div class="home-section-head">
        <h2>最近周报</h2>
      </div>
      <div class="home-side-list">
        {
          lifePosts.map(post => (
            <a
              class="home-side-card"
              href={PostUtils.getPath(
                post.id,
                post.filePath,
                true,
                post.data.date,
                post.data.timezone
              )}
            >
              <h3>{post.data.title}</h3>
              <p>
                {post.data.description?.trim() ||
                  PostUtils.getDescription(post.body ?? "")}
              </p>
            </a>
          ))
        }
      </div>
      <div class="home-section-action">
        <LinkButton
          href="/categories/weekly"
          class="home-section-link inline-flex items-center gap-1.5 border-0 bg-transparent px-0 py-0 text-sm text-[var(--accent)] no-underline outline-[var(--accent)] transition-colors hover:text-[var(--accent-dark)] focus-visible:outline-2 focus-visible:outline-offset-2"
        >
          查看全部周报
        </LinkButton>
      </div>
    </aside>
  </section>
</Layout>

<style>
  .home-section,
  .home-side-card {
    border: 1px solid var(--border);
    border-radius: 1.25rem;
  }

  .home-section-head h2 {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .home-side-card h3 {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.45;
    color: var(--accent);
  }

  .home-section-head p,
  .home-side-card p {
    color: var(--text-secondary);
  }

  .home-section {
    margin-bottom: 1.25rem;
    padding: 1.25rem;
    background: var(--background);
  }

  .home-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
    flex-wrap: wrap;
  }

  .home-section-head p {
    margin: 0.35rem 0 0;
  }

  .home-section-link {
    flex-shrink: 0;
    line-height: 1.45;
  }

  .home-section-action {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }

  .home-section-head-action {
    margin-left: auto;
    display: flex;
  }

  .home-section-head-action--mobile {
    display: none;
  }

  .home-split {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    align-items: start;
  }

  .home-card-list {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  .home-main-panel,
  .home-side-panel {
    min-width: 0;
    display: flex;
    flex-direction: column;
    border-radius: 1.25rem;
    background: var(--background);
  }

  .home-side-list {
    display: grid;
    gap: 0.875rem;
  }

  .home-side-card {
    display: block;
    padding: 1rem;
    color: inherit;
    text-decoration: none;
    background: var(--background-secondary);
  }

  .home-side-card b {
    display: block;
    font-size: 0.825rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .home-side-card p {
    margin: 0.6rem 0 0;
    font-size: 0.875rem;
    line-height: 1.65;
  }

  @media (min-width: 900px) {
    .home-split {
      gap: 1.4rem;
      grid-template-columns: minmax(0, 1.32fr) minmax(360px, 1.08fr);
    }
  }

  @media (max-width: 700px) {
    .home-section-head-action--mobile {
      display: flex;
    }

    .home-section-action.home-section-action--desktop {
      display: none;
    }

    .home-section-head {
      align-items: center;
      gap: 0.75rem;
    }
  }
</style>
