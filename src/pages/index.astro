---
/**
 * 首页
 *
 * @fileoverview 四宫格：最近博客、最近周报、最近翻译、最近 Wiki（各取自对应集合）。
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import { PostUtils } from "@/utils/postUtils";
import { SITE } from "@/config";

/** 与 /og/index.png 一致 */
export const pageSlug = "index";
export const pageTitle = SITE.title;
export const pageDescription = SITE.description;

const n = SITE.postPerIndex;

const latestPosts = PostUtils.sort(await getCollection("posts")).slice(0, n);
const latestBriefs = PostUtils.sort(await getCollection("briefs")).slice(0, n);
const latestTranslation = PostUtils.sort(
  await getCollection("translation")
).slice(0, n);
const latestWiki = PostUtils.sort(await getCollection("wiki")).slice(0, n);
---

<Layout title={pageTitle} description={pageDescription}>
  <section
    class="home-index home-index--grid grid w-full min-w-0 grid-cols-1 gap-7 md:grid-cols-2 md:gap-x-8 md:gap-y-7 lg:gap-x-10 lg:gap-y-1"
  >
    <section class="min-w-0" aria-labelledby="home-latest-posts-heading">
      <header class="mb-1.5">
        <h3
          id="home-latest-posts-heading"
          class="mt-0 mb-0.5 text-base"
        >
          最近博客
        </h3>
        <p class="mt-0.5 mb-0 text-sm leading-snug text-pretty text-muted">
          仅包含发布在博客目录下的长文（技术、生活等）。
          <a href="/posts" class="text-accent no-underline hover:underline">
            全部博客
          </a>
        </p>
      </header>
      <ul class="post-cards-list m-0 list-none p-0" aria-label="博客列表">
        {latestPosts.map(post => <Card openInNewTab={false} {...post} />)}
      </ul>
    </section>

    <section class="min-w-0" aria-labelledby="home-latest-briefs-heading">
      <header class="mb-1.5">
        <h3
          id="home-latest-briefs-heading"
          class="mt-0 mb-0.5 text-base"
        >
          最近周报
        </h3>
        <p class="mt-0.5 mb-0 text-sm leading-snug text-pretty text-muted">
          记录每周开发进展、工具尝试和一些阶段性想法。
          <a href="/briefs" class="text-accent no-underline hover:underline">
            全部周报
          </a>
        </p>
      </header>
      <ul class="post-cards-list m-0 list-none p-0" aria-label="周报列表">
        {
          latestBriefs.map(post => (
            <Card openInNewTab={false} listKind="weekly" {...post} />
          ))
        }
      </ul>
    </section>

    <section class="min-w-0" aria-labelledby="home-latest-translation-heading">
      <header class="mb-1.5">
        <h3
          id="home-latest-translation-heading"
          class="mt-0 mb-0.5 text-base"
        >
          最近翻译
        </h3>
        <p class="mt-0.5 mb-0 text-sm leading-snug text-pretty text-muted">
          外文技术文章的译文与笔记。
          <a
            href="/translation"
            class="text-accent no-underline hover:underline"
          >
            全部翻译
          </a>
        </p>
      </header>
      <ul class="post-cards-list m-0 list-none p-0" aria-label="译文列表">
        {
          latestTranslation.map(post => (
            <Card openInNewTab={false} dateFormat="absolute" {...post} />
          ))
        }
      </ul>
    </section>

    <section class="min-w-0" aria-labelledby="home-latest-wiki-heading">
      <header class="mb-1.5">
        <h3 id="home-latest-wiki-heading" class="mt-0 mb-0.5 text-base">
          最近 Wiki
        </h3>
        <p class="mt-0.5 mb-0 text-sm leading-snug text-pretty text-muted">
          主题索引与长期维护的笔记条目。
          <a href="/wiki" class="text-accent no-underline hover:underline">
            全部 Wiki
          </a>
        </p>
      </header>
      <ul class="post-cards-list m-0 list-none p-0" aria-label="Wiki 列表">
        {
          latestWiki.map(post => (
            <Card openInNewTab={false} dateFormat="absolute" {...post} />
          ))
        }
      </ul>
    </section>
  </section>
</Layout>
