---
/**
 * 首页
 *
 * @fileoverview 聚合站点入口：首屏双栏为最近周报（左/上）与最近文章（右/下）；最近文章不含周报分类。
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import { PostUtils, slugifyStr } from "@/utils/postUtils";
import { SITE } from "@/config";

/** 与 /og/index.png 一致 */
export const pageSlug = "index";
export const pageTitle = SITE.title;
export const pageDescription = SITE.description;

const publishedPosts = PostUtils.getPublishedPosts(await getCollection("blog"));
const sortedPosts = PostUtils.sort(publishedPosts);

const latestPosts = sortedPosts
  .filter(
    post => !post.data.categories.some(cat => slugifyStr(cat) === "weekly")
  )
  .slice(0, SITE.postPerIndex);
const lifePosts = PostUtils.getPostsByCategory(sortedPosts, "weekly").slice(
  0,
  6
);
---

<Layout title={pageTitle} description={pageDescription}>
  <section
    class="flex w-full min-w-0 flex-col gap-12 md:flex-row md:items-start md:gap-x-8 md:gap-y-0 lg:gap-x-10"
  >
    <div class="min-w-0 md:basis-[52%] lg:basis-[52%]">
      <header class="mb-2.5">
        <h3 class="mt-0 mb-1">最近文章</h3>
        <p class="mt-1 mb-0 text-sm leading-snug text-pretty text-muted">
          优先展示最近更新的技术文章、知识库条目和翻译内容。
          <a href="/posts" class="text-accent no-underline hover:underline">
            查看全部
          </a>
        </p>
      </header>
      <ul class="post-cards-list m-0 list-none p-0">
        {latestPosts.map(post => <Card openInNewTab={false} {...post} />)}
      </ul>
    </div>

    <aside class="min-w-0 md:basis-[48%] lg:basis-[48%]">
      <header class="mb-2.5">
        <h3 class="mt-0 mb-1">最近周报</h3>
        <p class="mt-1 mb-0 text-sm leading-snug text-pretty text-muted">
          记录每周开发进展、工具尝试和一些阶段性想法。
          <a
            href="/categories/weekly"
            class="text-accent no-underline hover:underline"
          >
            查看全部
          </a>
        </p>
      </header>
      <ul class="post-cards-list m-0 list-none p-0">
        {
          lifePosts.map(post => (
            <Card openInNewTab={false} listKind="weekly" {...post} />
          ))
        }
      </ul>
    </aside>
  </section>
</Layout>
