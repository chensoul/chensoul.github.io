---
/**
 * 标签详情页
 *
 * @fileoverview 展示某一标签下的文章列表；getStaticPaths 为每个标签生成路由，首屏显示 postPerIndex 条，其余由懒加载或「加载更多」展示。
 */
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import TaxonomySummary from "@/components/TaxonomySummary.astro";
import { getCategoryMeta, PostUtils, slugifyStr } from "@/utils/postUtils";
import { SITE } from "@/config";

export const pageTitle = `标签 | ${SITE.title}`;

/** 生成静态路径：每个标签一个路由，该标签下全部文章由懒加载分批显示 */
export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const publishedPosts = PostUtils.getPublishedPosts(
    await getCollection("blog")
  );
  const tags = PostUtils.getUniqueTags(publishedPosts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = PostUtils.getPostsByTag(publishedPosts, tag);
    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: tagPosts.length,
    });
  });
}

const { page, tagName } = Astro.props;
const totalPosts = page.data.length;
const categoryCount = new Map<
  string,
  { categoryName: string; count: number }
>();
page.data.forEach(post => {
  post.data.categories.forEach(category => {
    const slug = slugifyStr(category);
    const categoryLabel = getCategoryMeta(category)?.name ?? category;
    const existing = categoryCount.get(slug);
    if (existing) {
      existing.count += 1;
    } else {
      categoryCount.set(slug, { categoryName: categoryLabel, count: 1 });
    }
  });
});
const topCategories = Array.from(categoryCount.entries())
  .sort(
    (a, b) =>
      b[1].count - a[1].count ||
      a[1].categoryName.localeCompare(b[1].categoryName, "zh-CN")
  )
  .slice(0, 6);
const relatedCategories = topCategories.map(
  ([category, { categoryName, count }]) => ({
    href: `/categories/${category}`,
    label: categoryName,
    count,
  })
);
---

<Layout title={pageTitle} robots="noindex,follow">
  <section class="tag-head mb-5">
    <nav class="taxonomy-breadcrumbs" aria-label="面包屑导航">
      <a href="/">首页</a>
      <span>/</span>
      <a href="/tags">标签</a>
      <span>/</span>
      <span>{tagName}</span>
    </nav>
    <h1 class="mb-2 text-xl font-semibold">{tagName}</h1>
    <p class="mb-2 text-sm text-[var(--text-secondary)]">
      按时间倒序浏览标签「{tagName}」下的 {totalPosts} 篇文章。
    </p>
    <TaxonomySummary title="相关分类" items={relatedCategories} />
  </section>
  <ul class="tag-posts-list list-none pl-0">
    {
      page.data.map((data, i) => (
        <Card
          {...data}
          itemClass="tag-post-item"
          hidden={i >= SITE.postPerIndex}
          dateFormat="absolute"
        />
      ))
    }
  </ul>
  <div
    id="tag-posts-sentinel"
    data-init={SITE.postPerIndex}
    data-chunk={SITE.postPerIndex}
  >
  </div>
</Layout>

{SITE.lazyListJsUrl && <script is:inline src={SITE.lazyListJsUrl} />}
<script is:inline>
  let bootTimer;
  function boot() {
    if (typeof window.setupLazyList !== "function") return false;
    if (bootTimer) {
      clearTimeout(bootTimer);
      bootTimer = undefined;
    }
    window.setupLazyList({
      sentinelId: "tag-posts-sentinel",
      itemSelector: ".tag-post-item",
    });
    return true;
  }
  function scheduleBoot() {
    if (boot()) return;
    if (bootTimer) clearTimeout(bootTimer);
    bootTimer = setTimeout(scheduleBoot, 120);
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleBoot, { once: true });
  } else {
    scheduleBoot();
  }
  window.addEventListener("load", scheduleBoot);
  document.addEventListener("astro:page-load", scheduleBoot);
</script>

<style>
  .taxonomy-breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .taxonomy-breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .taxonomy-breadcrumbs a:hover {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
