---
/**
 * 标签索引页
 *
 * @fileoverview 列出全站所有标签及使用次数，使用 Tag 组件渲染为可点击的标签云，点击进入 /tags/[tag]。
 */
import { getAllBlogLike } from "@/utils/contentCollections";
import Layout from "@/layouts/Layout.astro";
import ListLayout from "@/layouts/ListLayout.astro";
import Tag from "@/components/Tag.astro";
import { PostUtils } from "@/utils/postUtils";
import { SITE } from "@/config";

export const prerender = true;
export const pageTitle = `标签 | ${SITE.title}`;

const publishedPosts = PostUtils.getPublishedPosts(await getAllBlogLike());
const allTags = PostUtils.getUniqueTags(publishedPosts).sort(
  (a, b) => b.count - a.count || a.tagName.localeCompare(b.tagName, "zh-CN")
);
const topTags = allTags.slice(0, 10);
const otherTags = [...allTags.slice(10)].sort((a, b) =>
  a.tagName.localeCompare(b.tagName, "zh-CN")
);
---

<Layout title={pageTitle} robots="noindex,follow">
  <ListLayout
    title="标签"
    description="热门标签按使用次数排序，其余按名称拼音排序。"
  >
    <div class="space-y-8">
      {
        topTags.length > 0 && (
          <section>
            <h2>热门标签</h2>
            <ul class="m-0 flex list-none flex-wrap gap-2 p-0">
              {topTags.map(({ tag, tagName, count }) => (
                <Tag tag={tag} tagName={tagName} count={count} size="sm" />
              ))}
            </ul>
          </section>
        )
      }
      {
        otherTags.length > 0 && (
          <section>
            <h2>全部标签</h2>
            <ul class="m-0 flex list-none flex-wrap gap-2 p-0">
              {otherTags.map(({ tag, tagName, count }) => (
                <Tag tag={tag} tagName={tagName} count={count} size="sm" />
              ))}
            </ul>
          </section>
        )
      }
    </div>
  </ListLayout>
</Layout>
