---
/**
 * 标签索引页
 *
 * @fileoverview 列出全站所有标签及使用次数，使用 Tag 组件渲染为可点击的标签云，点击进入 /tags/[tag]。
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Tag from "@/components/Tag.astro";
import TaxonomySummary from "@/components/TaxonomySummary.astro";
import { PostUtils } from "@/utils/postUtils";
import { SITE } from "@/config";

export const pageSlug = "tags";
export const pageTitle = `标签 | ${SITE.title}`;

const publishedPosts = PostUtils.getPublishedPosts(await getCollection("blog"));
const tags = PostUtils.getUniqueTags(publishedPosts).sort(
  (a, b) => b.count - a.count || a.tagName.localeCompare(b.tagName, "zh-CN")
);
const topTags = tags.slice(0, 10);
const otherTags = [...tags.slice(10)].sort((a, b) =>
  a.tagName.localeCompare(b.tagName, "zh-CN")
);
---

<Layout title={pageTitle} robots="noindex,follow">
  <TaxonomySummary items={[]} />
  {
    topTags.length > 0 && (
      <section>
        <h2>热门标签</h2>
        <ul class="m-0 flex list-none flex-wrap gap-2 p-0">
          {topTags.map(({ tag, tagName, count }) => (
            <Tag {tag} {tagName} {count} size="sm" />
          ))}
        </ul>
      </section>
    )
  }
  {
    otherTags.length > 0 && (
      <section>
        <h2>全部标签</h2>
        <ul class="m-0 flex list-none flex-wrap gap-2 p-0">
          {otherTags.map(({ tag, tagName, count }) => (
            <Tag {tag} {tagName} {count} size="sm" />
          ))}
        </ul>
      </section>
    )
  }
</Layout>
