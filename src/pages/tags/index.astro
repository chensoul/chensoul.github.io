---
/**
 * 标签索引页
 *
 * @fileoverview 列出全站所有标签及使用次数，使用 Tag 组件渲染为可点击的标签云，点击进入 /tags/[tag]。
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Tag from "@/components/Tag.astro";
import { PostUtils } from "@/utils/postUtils";
import { SITE } from "@/config";

export const pageSlug = "tags";
export const pageTitle = `标签 | ${SITE.title}`;

const publishedPosts = PostUtils.getPublishedPosts(await getCollection("blog"));
const tags = PostUtils.getUniqueTags(publishedPosts).sort(
  (a, b) => b.count - a.count || a.tagName.localeCompare(b.tagName, "zh-CN")
);
const topTags = tags.slice(0, 10);
const otherTags = [...tags.slice(10)].sort((a, b) =>
  a.tagName.localeCompare(b.tagName, "zh-CN")
);
---

<Layout title={pageTitle} robots="noindex,follow">
  {
    topTags.length > 0 && (
      <section class="tags-section">
        <h2 class="tags-heading">热门标签</h2>
        <ul class="tags-list">
          {topTags.map(({ tag, tagName, count }) => (
            <Tag {tag} {tagName} {count} size="sm" />
          ))}
        </ul>
      </section>
    )
  }
  {
    otherTags.length > 0 && (
      <section class="tags-section">
        <h2 class="tags-heading">全部标签</h2>
        <ul class="tags-list">
          {otherTags.map(({ tag, tagName, count }) => (
            <Tag {tag} {tagName} {count} size="sm" />
          ))}
        </ul>
      </section>
    )
  }
</Layout>

<style>
  .tags-section {
    margin-top: 0.5rem;
  }

  .tags-section + .tags-section {
    margin-top: 1.25rem;
  }

  .tags-heading {
    margin: 0 0 0.75rem;
    font-weight: 600;
  }

  .tags-list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
  }

  .tags-section:first-of-type .tags-list {
    gap: 0.35rem;
  }

  .tags-list li {
    margin: 0;
  }
</style>
