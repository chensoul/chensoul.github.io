---
import Layout from "@/layouts/Layout.astro";
import MarkdownIt from "markdown-it";
import { SITE } from "@/config";
import { readContentPage } from "@/utils/contentPage";

const pageSlug = "links";
const pageData = readContentPage(`${pageSlug}.md`);
const pageTitle = pageData.frontmatter.title || SITE.title;
const pageDescription = pageData.frontmatter.description || SITE.description;

export { pageDescription, pageSlug, pageTitle };

// 使用 markdown-it 渲染 markdown（不启用 typographer，避免链接 URL 中的英文逗号被替换为中文逗号）
const md = new MarkdownIt({
  html: true, // 允许 HTML
  linkify: true, // 自动转换 URL 为链接
  typographer: false, // 关闭标点替换，保证链接里的英文逗号不变
});
const htmlContent = md.render(pageData.content);
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schemaType="CollectionPage"
>
  <div class="page-content">
    <Fragment set:html={htmlContent} />
  </div>
</Layout>
