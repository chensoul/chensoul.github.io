---
import "@/styles/taxonomy-pill.css";

/**
 * 关联导航摘要 + 胶囊（taxonomy-pill）全局样式
 *
 * @fileoverview 在分类页、标签页头部展示一组关联入口；全局样式供标签云、归档页分类/年份、文章元信息分类等共用。仅需样式时可传 items={[]}。
 */

export interface TaxonomySummaryItem {
  href: string;
  label: string;
  count?: number;
}

export interface Props {
  /** 有 items 时展示在列表前；仅注入胶囊样式时可省略 */
  title?: string;
  items: TaxonomySummaryItem[];
}

const { title = "", items } = Astro.props;
---
{
  items.length > 0 && (
    <section class="taxonomy-summary my-4 first:mt-0" aria-label={title}>
      <div class="m-0 flex flex-wrap items-center gap-2 text-sm leading-relaxed text-[var(--text-secondary)]">
        <span class="shrink-0 font-semibold text-[var(--text-primary)]">
          {title}：
        </span>
        {items.map(item => (
          <a href={item.href} class="no-underline">
            <span class="taxonomy-pill">
              <span>{item.label}</span>
              {item.count !== undefined && item.count !== null && (
                <span class="taxonomy-pill-count taxonomy-pill-count--tag">
                  {item.count}
                </span>
              )}
            </span>
          </a>
        ))}
      </div>
    </section>
  )
}
