---
/**
 * 关联导航摘要组件
 *
 * @fileoverview 在分类页、标签页头部展示一组关联入口。
 */

export interface TaxonomySummaryItem {
  href: string;
  label: string;
  count?: number;
}

export interface Props {
  title: string;
  items: TaxonomySummaryItem[];
}

const { title, items } = Astro.props;
---

{
  items.length > 0 && (
    <section class="taxonomy-summary" aria-label={title}>
      <p class="taxonomy-summary-text">
        <span class="taxonomy-summary-label">{title}：</span>
        {items.map(item => (
          <a href={item.href} class="taxonomy-summary-link">
            <span class="taxonomy-pill">
              <span>{item.label}</span>
              {(item.count || item.count === 0) && (
                <span class="taxonomy-pill-count">（{item.count}）</span>
              )}
            </span>
          </a>
        ))}
      </p>
    </section>
  )
}

<style>
  @media (max-width: 700px) {
    .taxonomy-summary-text {
      gap: 0.3rem 0.6rem;
    }
  }
</style>
