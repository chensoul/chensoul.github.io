---
import "@/styles/taxonomy-pill.css";

/**
 * 关联导航摘要 + 胶囊（taxonomy-pill）全局样式
 *
 * @fileoverview 在分类页、标签页头部展示一组关联入口；全局样式供标签云、归档页分类/年份、文章元信息分类等共用。仅需样式时可传 items={[]}。
 */

export interface TaxonomySummaryItem {
  href: string;
  label: string;
  count?: number;
}

export interface Props {
  /** 有 items 时展示在列表前；仅注入胶囊样式时可省略 */
  title?: string;
  items: TaxonomySummaryItem[];
  /** 合并到根 `section`（归档页等可用 `my-0` 收紧间距） */
  class?: string;
}

const { title = "", items, class: className = "" } = Astro.props;
---
{
  items.length > 0 && (
    <section
      class:list={["taxonomy-summary my-0 first:mt-0", className]}
      aria-label={title}
    >
      <div
        class="m-0 flex flex-wrap items-start gap-x-3 gap-y-2 text-sm leading-relaxed text-muted"
      >
        <span class="min-w-12 shrink-0 leading-8 font-semibold text-foreground">
          {title}：
        </span>
        {items.map(item => (
          <a href={item.href} class="inline-flex no-underline">
            <span class="taxonomy-pill">
              <span>{item.label}</span>
              {item.count !== undefined && item.count !== null && (
                <span class="taxonomy-pill-count taxonomy-pill-count--tag">
                  {item.count}
                </span>
              )}
            </span>
          </a>
        ))}
      </div>
    </section>
  )
}
