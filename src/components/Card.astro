---
import type { BlogLikeEntry } from "@/utils/contentCollections";
import { ArticleTime } from "@/utils/articleTime";
import { formatFeedDate, PostUtils } from "@/utils/postUtils";
import { SITE } from "@/config";
import { siteImageHref } from "@/utils/blogImages";

/**
 * 组件属性接口
 *
 * 扩展自 {@link BlogLikeEntry}，包含文章的所有元数据
 *
 * @property openInNewTab - 标题链接是否新标签打开（默认 true）
 * @property itemClass - 额外的 CSS 类名
 * @property hidden - 是否隐藏此卡片
 * @property dateFormat - 日期显示格式：relative（相对时间）或 absolute（绝对时间 YYYY-MM-DD）
 * @property listKind - article：第二行为时间；weekly：第二行为摘要（.pcard-desc）；聚合用 mode="feed"
 */
type BlogCardProps = BlogLikeEntry & {
  mode?: "post";
  openInNewTab?: boolean;
  listKind?: "article" | "weekly";
  itemClass?: string;
  hidden?: boolean;
  dateFormat?: "relative" | "absolute";
};

interface FeedCardProps {
  mode: "feed";
  title: string;
  link: string;
  published: string;
  blogName?: string;
  avatar?: string;
}

export type Props = BlogCardProps | FeedCardProps;

const rawProps = Astro.props as Props;
const isFeedCard = rawProps.mode === "feed";

const blogProps = rawProps as BlogCardProps;
const feedProps = rawProps as FeedCardProps;

const openInNewTab = !isFeedCard ? (blogProps.openInNewTab ?? true) : false;
const listKind = !isFeedCard ? (blogProps.listKind ?? "article") : "feed";
const itemClass = !isFeedCard ? blogProps.itemClass : undefined;
const hidden = !isFeedCard ? (blogProps.hidden ?? false) : false;
const dateFormat = !isFeedCard
  ? (blogProps.dateFormat ?? "relative")
  : "relative";
const data = !isFeedCard ? blogProps.data : undefined;
const id = !isFeedCard ? blogProps.id : undefined;
const filePath = !isFeedCard ? blogProps.filePath : undefined;
const collection = !isFeedCard ? blogProps.collection : undefined;

const title = isFeedCard ? feedProps.title : data!.title;
const date = !isFeedCard ? data!.date : undefined;
const updated = !isFeedCard ? data!.updated : undefined;
const timezone = !isFeedCard ? data!.timezone : undefined;
const listFaviconSrc = isFeedCard
  ? undefined
  : PostUtils.resolveArticleListFaviconImgSrc(data!.favicon, data!.categories);

const weeklyDescription =
  !isFeedCard && listKind === "weekly"
    ? (
        data!.description?.trim() ||
        PostUtils.getDescription(blogProps.body ?? "")
      ).trim()
    : "";

const feedDate = isFeedCard ? formatFeedDate(feedProps.published) : "";
const feedBlogName = isFeedCard ? (feedProps.blogName?.trim() ?? "") : "";

const articleListTime =
  !isFeedCard && listKind !== "weekly"
    ? ArticleTime.getDisplay(date!, updated, timezone, dateFormat)
    : null;

let avatarSrc = "";
if (isFeedCard) {
  avatarSrc = feedProps.avatar?.trim() || SITE.feeds.fallbackAvatarUrl || "";
  if (
    avatarSrc &&
    !/^https?:\/\//.test(avatarSrc) &&
    !avatarSrc.startsWith("//")
  ) {
    if (!avatarSrc.startsWith("/images/")) {
      const name = avatarSrc.replace(/^\//, "");
      avatarSrc = `/images/_favicons/${name}`;
    }
    avatarSrc = siteImageHref(avatarSrc);
  }
}
---

<li class:list={["pcard", itemClass, { hidden }]}>
  <div class="pcard-inner">
    {
      isFeedCard
        ? avatarSrc && (
            <img
              src={avatarSrc}
              alt=""
              width={40}
              height={40}
              loading="lazy"
              decoding="async"
            />
          )
        : listFaviconSrc && (
            <img
              src={listFaviconSrc}
              alt={title}
              width={40}
              height={40}
              loading="lazy"
              decoding="async"
            />
          )
    }
    <div class="pcard-body">
      {
        isFeedCard ? (
          <p class="pcard-title">
            {feedProps.link && feedProps.link !== "#" ? (
              <a
                href={feedProps.link}
                target="_blank"
                rel="noopener noreferrer"
              >
                {title || "无标题"}
              </a>
            ) : (
              <span>{title || "无标题"}</span>
            )}
          </p>
        ) : (
          <p class="pcard-title">
            <a
              href={PostUtils.getPath(
                id!,
                filePath!,
                true,
                date!,
                timezone,
                data?.slug,
                collection!
              )}
              target={openInNewTab ? "_blank" : undefined}
              rel={openInNewTab ? "noopener noreferrer" : undefined}
            >
              {title}
            </a>
          </p>
        )
      }
      {
        isFeedCard ? (
          <div class="pcard-meta">
            <span data-feed-published={feedProps.published}>{feedDate}</span>
            {feedBlogName && (
              <>
                <span aria-hidden="true">·</span>
                <span>{feedBlogName}</span>
              </>
            )}
          </div>
        ) : (
          <>
            {listKind !== "weekly" && articleListTime && (
              <div class="pcard-meta">
                <time
                  class="pcard-meta__time"
                  datetime={articleListTime.iso}
                  title={articleListTime.titleAttr}
                  data-date-format={dateFormat}
                >
                  {articleListTime.display}
                </time>
              </div>
            )}
            {listKind === "weekly" && (
              <>
                {weeklyDescription && (
                  <p class="pcard-desc">{weeklyDescription}</p>
                )}
              </>
            )}
          </>
        )
      }
    </div>
  </div>
</li>

<style is:global>
  .pcard {
    --pcard-thumb-size: 40px;
    /* 条与条之间的垂直留白（首页与列表页共用） */
    --pcard-padding-y: 0.06rem;
    /* 相邻两条之间的收紧量（负 margin-top，仅作用于 .post-cards-list 内第二条起） */
    --pcard-list-tighten: -0.1rem;
    --pcard-inner-gap: 0.45rem;
    --pcard-title-size: 0.86rem;
    --pcard-title-line-height: 1.36;
    --pcard-title-lines: 2;
    --pcard-title-gap: 0.05rem;
    /* 第二行：日期 / 聚合元信息 / 周报摘要 — 共用字号与行高 */
    --pcard-meta-size: 0.72rem;
    --pcard-meta-line-height: 1.36;
    /*
     * min-height 第一路：至少包住缩略图 + 上下留白（原写死 1rem，现可调）
     * 第二路：标题两行 + 第二行 + padding；max() 取二者较大
     */
    --pcard-inner-min-thumb-slack: 0.35rem;
  }

  .pcard {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pcard.hidden {
    display: none;
  }

  .pcard-inner {
    display: flex;
    gap: var(--pcard-inner-gap);
    align-items: flex-start;
    border: none;
    border-radius: 8px;
    background: transparent;
    padding: var(--pcard-padding-y) 0;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
    min-height: max(
      calc(
        var(--pcard-thumb-size) + var(--pcard-inner-min-thumb-slack)
      ),
      calc(
        var(--pcard-title-size) * var(--pcard-title-line-height) *
          var(--pcard-title-lines) + var(--pcard-title-gap) +
          var(--pcard-meta-size) * var(--pcard-meta-line-height) +
          var(--pcard-padding-y) * 2
      )
    );
  }

  .pcard-inner:hover {
    background: color-mix(in srgb, var(--accent) 3%, transparent);
    transform: translateY(-1px);
  }

  .pcard-inner > img {
    width: var(--pcard-thumb-size);
    min-width: var(--pcard-thumb-size);
    max-width: none;
    height: var(--pcard-thumb-size);
    flex: 0 0 var(--pcard-thumb-size);
    flex-shrink: 0;
    align-self: flex-start;
    display: block;
    border-radius: 9px;
    object-fit: cover;
  }

  .pcard-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0;
  }

  .pcard :where(ul, ol, menu) {
    padding-left: 0;
  }

  .pcard-title {
    margin: 0 0 var(--pcard-title-gap);
    font-size: var(--pcard-title-size);
    line-height: var(--pcard-title-line-height);
    color: var(--text-primary);
    overflow-wrap: break-word;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }

  .pcard-title a {
    color: var(--accent);
    text-decoration: none;
  }

  .pcard-title a:hover {
    color: var(--accent-dark);
    text-decoration: underline;
  }

  .pcard-meta {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.18rem;
    min-width: 0;
    font-size: var(--pcard-meta-size);
    line-height: var(--pcard-meta-line-height);
    color: var(--text-secondary);
    overflow: hidden;
    white-space: nowrap;
  }

  .pcard-meta__time {
    font-weight: 400;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    color: inherit;
  }

  .pcard-meta :is(span, a) {
    font-size: inherit;
    line-height: inherit;
  }

  .pcard-meta > :first-child {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .pcard-meta > :not(:first-child):not([aria-hidden="true"]) {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pcard-meta a {
    display: inline-block;
    min-width: 0;
    max-width: 100%;
    color: var(--accent);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pcard-meta a:hover {
    text-decoration: underline;
  }

  /* 仅周报用：第二行摘要，单行省略（仅 briefs + listKind=weekly 会渲染 .pcard-desc） */
  .pcard-desc {
    margin: 0;
    font-size: var(--pcard-meta-size);
    line-height: var(--pcard-meta-line-height);
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    line-clamp: 1;
    overflow: hidden;
  }

  .pcard-meta > [aria-hidden="true"] {
    flex: 0 0 auto;
    opacity: 0.6;
  }

  /* 包裹 Card 的列表（含首页 section > div > ul 等嵌套，主选择器匹配不到） */
  .post-cards-list {
    list-style: none;
    margin: 0;
    padding: 0;
    padding-inline-start: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-cards-list > .pcard + .pcard {
    margin-top: var(--pcard-list-tighten);
  }

  @media (max-width: 640px) {
    .pcard {
      --pcard-inner-min-thumb-slack: 0.32rem;
      --pcard-padding-y: 0.1rem;
      --pcard-list-tighten: -0.08rem;
      --pcard-inner-gap: 0.48rem;
      --pcard-title-size: 0.83rem;
      --pcard-meta-size: 0.7rem;
      --pcard-title-gap: 0.07rem;
      --pcard-title-line-height: 1.35;
      --pcard-meta-line-height: 1.35;
    }

    .pcard-inner > img {
      flex-shrink: 0;
      border-radius: 8px;
    }

    .post-cards-list {
      gap: 0;
    }
  }
</style>
