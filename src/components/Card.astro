---
import type { CollectionEntry } from "astro:content";
import { getCategoryMeta, PostUtils, slugifyStr } from "@/utils/postUtils";
import Datetime from "./Datetime.astro";
import { SITE } from "@/config";
import { formatFeedDate } from "@/utils/feedDate";

/**
 * 组件属性接口
 *
 * 扩展自 CollectionEntry<"blog">，包含文章的所有元数据
 *
 * @property openInNewTab - 标题链接是否新标签打开（默认 true）
 * @property itemClass - 额外的 CSS 类名
 * @property hidden - 是否隐藏此卡片
 * @property dateFormat - 日期显示格式：relative（相对时间）或 absolute（绝对时间 YYYY-MM-DD）
 * @property listKind - article：时间+分类链接；weekly：再加描述行；邻居订阅用 mode="feed"
 */
interface BlogCardProps extends CollectionEntry<"blog"> {
  mode?: "post";
  openInNewTab?: boolean;
  listKind?: "article" | "weekly";
  itemClass?: string;
  hidden?: boolean;
  dateFormat?: "relative" | "absolute";
}

interface FeedCardProps {
  mode: "feed";
  title: string;
  link: string;
  published: string;
  blogName?: string;
  avatar?: string;
}

export type Props = BlogCardProps | FeedCardProps;

const rawProps = Astro.props as Props;
const isFeedCard = rawProps.mode === "feed";

const blogProps = rawProps as BlogCardProps;
const feedProps = rawProps as FeedCardProps;

const openInNewTab = !isFeedCard ? (blogProps.openInNewTab ?? true) : false;
const listKind = !isFeedCard ? (blogProps.listKind ?? "article") : "feed";
const itemClass = !isFeedCard ? blogProps.itemClass : undefined;
const hidden = !isFeedCard ? (blogProps.hidden ?? false) : false;
const dateFormat = !isFeedCard
  ? (blogProps.dateFormat ?? "relative")
  : "relative";
const data = !isFeedCard ? blogProps.data : undefined;
const id = !isFeedCard ? blogProps.id : undefined;
const filePath = !isFeedCard ? blogProps.filePath : undefined;

const title = isFeedCard ? feedProps.title : data!.title;
const date = !isFeedCard ? data!.date : undefined;
const updated = !isFeedCard ? data!.updated : undefined;
const timezone = !isFeedCard ? data!.timezone : undefined;
const cover = !isFeedCard ? data!.cover : undefined;
const categories = !isFeedCard ? data!.categories : undefined;
const primaryCategory = Array.isArray(categories) ? categories[0] : undefined;
const primaryCategoryLabel =
  getCategoryMeta(primaryCategory)?.name ?? primaryCategory;
const primaryCategorySlug = primaryCategory
  ? slugifyStr(primaryCategory)
  : undefined;

/**
 * 构建封面图 URL
 *
 * - cover 为空：取首个分类对应缩略图 /thumbs/{category}.svg，无分类则 /thumbs/blank.svg，再按下方规则解析
 * - 以 http:// 或 https:// 开头：原样返回（绝对地址）
 * - 其他（相对路径或 /images、/thumbs 等）：
 *   - /images、/thumbs：始终走站内同源资源，减少列表页的跨域图片请求
 *   - 其余相对路径：开发环境走站内路径；生产环境若配置 CDN 则拼接完整地址
 *
 * @returns 用于 <img src> 的完整或相对 URL
 */
const buildCoverSrc = (): string | undefined => {
  if (isFeedCard) return undefined;

  const resolveLocalSrc = (src: string): string => {
    const normalizedSrc = src.startsWith("/") ? src : `/${src}`;

    if (/^\/(images|thumbs)\//.test(normalizedSrc)) {
      return normalizedSrc;
    }

    if (import.meta.env.DEV) {
      return normalizedSrc;
    }

    const imagesBase = (SITE.imageConfig.imagesUrl ?? "")
      .trim()
      .replace(/\/$/, "");
    return imagesBase ? `${imagesBase}${normalizedSrc}` : normalizedSrc;
  };

  const rawImage = typeof cover === "string" ? cover.trim() : "";

  if (rawImage) {
    if (rawImage.startsWith("http://") || rawImage.startsWith("https://")) {
      return rawImage;
    }
    return resolveLocalSrc(rawImage);
  }

  const firstCategory = Array.isArray(categories) ? categories[0] : undefined;
  const filename = firstCategory || "blank";
  return resolveLocalSrc(`/thumbs/${filename}.svg`);
};

const coverSrc = buildCoverSrc();

const weeklyDescription =
  !isFeedCard && listKind === "weekly"
    ? (
        data!.description?.trim() ||
        PostUtils.getDescription(blogProps.body ?? "")
      ).trim()
    : "";

const feedDate = isFeedCard ? formatFeedDate(feedProps.published) : "";
const feedBlogName = isFeedCard ? (feedProps.blogName?.trim() ?? "") : "";

let avatarSrc = "";
if (isFeedCard) {
  avatarSrc = feedProps.avatar?.trim() || SITE.feeds.fallbackAvatarUrl || "";
  if (
    avatarSrc &&
    !/^https?:\/\//.test(avatarSrc) &&
    !avatarSrc.startsWith("//")
  ) {
    const avatarHost =
      (SITE.feeds.cosHost && SITE.feeds.cosHost.trim()) || SITE.website;
    avatarSrc =
      avatarHost.replace(/\/$/, "") +
      (avatarSrc.startsWith("/") ? avatarSrc : `/${avatarSrc}`);
  }
}
---

<li class:list={["pcard", itemClass, { hidden }]}>
  <div class="pcard-inner">
    {
      isFeedCard
        ? avatarSrc && (
            <img
              src={avatarSrc}
              alt=""
              width={46}
              height={46}
              loading="lazy"
              decoding="async"
            />
          )
        : coverSrc && (
            <img
              src={coverSrc}
              alt={title}
              width={46}
              height={46}
              loading="lazy"
              decoding="async"
            />
          )
    }
    <div class="pcard-body">
      {
        isFeedCard ? (
          <p class="pcard-title">
            {feedProps.link && feedProps.link !== "#" ? (
              <a
                href={feedProps.link}
                target="_blank"
                rel="noopener noreferrer"
              >
                {title || "无标题"}
              </a>
            ) : (
              <span>{title || "无标题"}</span>
            )}
          </p>
        ) : (
          <p class="pcard-title">
            <a
              href={PostUtils.getPath(
                id!,
                filePath!,
                true,
                date!,
                timezone,
                data?.slug
              )}
              target={openInNewTab ? "_blank" : undefined}
              rel={openInNewTab ? "noopener noreferrer" : undefined}
            >
              {title}
            </a>
          </p>
        )
      }
      {
        isFeedCard ? (
          <div class="pcard-meta">
            <span data-feed-published={feedProps.published}>{feedDate}</span>
            {feedBlogName && (
              <>
                <span aria-hidden="true">·</span>
                <span>{feedBlogName}</span>
              </>
            )}
          </div>
        ) : (
          <>
            {listKind !== "weekly" && (
              <div class="pcard-meta">
                <Datetime
                  pubDatetime={date!}
                  modDatetime={updated}
                  {timezone}
                  format={dateFormat}
                />
                {primaryCategoryLabel && (
                  <>
                    <span aria-hidden="true">·</span>
                    <a href={`/categories/${primaryCategorySlug}`}>
                      {primaryCategoryLabel}
                    </a>
                  </>
                )}
              </div>
            )}
            {listKind === "weekly" && weeklyDescription && (
              <p class="pcard-desc">{weeklyDescription}</p>
            )}
          </>
        )
      }
    </div>
  </div>
</li>

<style is:global>
  .pcard {
    --pcard-thumb-size: 44px;
    --pcard-padding-y: 0.24rem;
    --pcard-title-size: 0.84rem;
    --pcard-title-line-height: 1.3;
    --pcard-title-lines: 2;
    --pcard-title-gap: 0.08rem;
    --pcard-meta-size: 0.8rem;
    --pcard-meta-line-height: 1.3;
  }

  .pcard {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pcard.hidden {
    display: none;
  }

  .pcard-inner {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    border: none;
    border-radius: 8px;
    background: transparent;
    padding: var(--pcard-padding-y) 0;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
    min-height: max(
      calc(var(--pcard-thumb-size) + var(--pcard-padding-y) * 2),
      calc(
        var(--pcard-title-size) * var(--pcard-title-line-height) *
          var(--pcard-title-lines) + var(--pcard-title-gap) +
          var(--pcard-meta-size) * var(--pcard-meta-line-height) +
          var(--pcard-padding-y) * 2
      )
    );
  }

  .pcard-inner:hover {
    background: color-mix(in srgb, var(--accent) 3%, transparent);
    transform: translateY(-1px);
  }

  .pcard-inner > img {
    width: var(--pcard-thumb-size);
    min-width: var(--pcard-thumb-size);
    max-width: none;
    height: var(--pcard-thumb-size);
    flex: 0 0 var(--pcard-thumb-size);
    flex-shrink: 0;
    align-self: flex-start;
    display: block;
    border-radius: 10px;
    object-fit: cover;
  }

  .pcard-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0;
  }

  .pcard :where(ul, ol, menu) {
    padding-left: 0;
  }

  .pcard-title {
    margin: 0 0 var(--pcard-title-gap);
    font-size: var(--pcard-title-size);
    line-height: var(--pcard-title-line-height);
    color: var(--text-primary);
    overflow-wrap: break-word;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }

  .pcard-title a {
    color: var(--accent);
    text-decoration: none;
  }

  .pcard-title a:hover {
    color: var(--accent-dark);
    text-decoration: underline;
  }

  .pcard-meta {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.18rem;
    min-width: 0;
    font-size: var(--pcard-meta-size);
    line-height: var(--pcard-meta-line-height);
    color: var(--text-secondary);
    overflow: hidden;
    white-space: nowrap;
  }

  /* Datetime 内 time 带 text-sm，与 meta 统一为同一字号 */
  .pcard-meta :is(time, span, a) {
    font-size: inherit;
    line-height: inherit;
  }

  .pcard-meta > :first-child {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .pcard-meta > :not(:first-child):not([aria-hidden="true"]) {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pcard-meta a {
    display: inline-block;
    min-width: 0;
    max-width: 100%;
    color: var(--accent);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pcard-meta a:hover {
    text-decoration: underline;
  }

  .pcard-desc {
    margin: 0.14rem 0 0;
    font-size: 0.76rem;
    line-height: 1.42;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }

  .pcard-meta > [aria-hidden="true"] {
    flex: 0 0 auto;
    opacity: 0.6;
  }

  /* 包裹 Card 的列表（含首页 section > div > ul 等嵌套，主选择器匹配不到） */
  .post-cards-list {
    list-style: none;
    margin: 0;
    padding: 0;
    padding-inline-start: 0;
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
  }

  @media (max-width: 640px) {
    .pcard {
      --pcard-thumb-size: 40px;
      --pcard-padding-y: 0.28rem;
      --pcard-title-size: 0.82rem;
      --pcard-title-gap: 0.12rem;
      --pcard-meta-size: 0.78rem;
    }

    .pcard-inner {
      gap: 0.6rem;
    }

    .pcard-inner > img {
      flex-shrink: 0;
      border-radius: 9px;
    }

    .pcard-title {
      line-height: 1.35;
    }

    .pcard-meta {
      line-height: 1.35;
    }

    .pcard-desc {
      margin-top: 0.16rem;
      line-height: 1.5;
    }

    .post-cards-list {
      gap: 0.16rem;
    }
  }
</style>
