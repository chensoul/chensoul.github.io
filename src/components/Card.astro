---
import type { CollectionEntry } from "astro:content";
import { getCategoryMeta, PostUtils, slugifyStr } from "@/utils/postUtils";
import Datetime from "./Datetime.astro";
import { SITE } from "@/config";

/**
 * 组件属性接口
 *
 * 扩展自 CollectionEntry<"blog">，包含文章的所有元数据
 *
 * @property variant - 标题级别（h2 或 h3）
 * @property itemClass - 额外的 CSS 类名
 * @property hidden - 是否隐藏此卡片
 * @property dateFormat - 日期显示格式：relative（相对时间）或 absolute（绝对时间 YYYY-MM-DD）
 * @property priority - 是否为 LCP 优先资源（首屏首图时设为 true，使用 fetchpriority="high"）
 */
export interface Props extends CollectionEntry<"blog"> {
  variant?: "h2" | "h3";
  itemClass?: string;
  hidden?: boolean;
  dateFormat?: "relative" | "absolute";
  priority?: boolean;
}

const {
  variant = "h2",
  data,
  id,
  filePath,
  itemClass,
  hidden = false,
  dateFormat = "relative",
  priority = false,
} = Astro.props;

// 解构文章元数据
const { title, date, updated, timezone, cover, categories } = data;
const primaryCategory = Array.isArray(categories) ? categories[0] : undefined;
const primaryCategoryLabel =
  getCategoryMeta(primaryCategory)?.name ?? primaryCategory;
const primaryCategorySlug = primaryCategory
  ? slugifyStr(primaryCategory)
  : undefined;

/**
 * 构建封面图 URL
 *
 * - cover 为空：取首个分类对应缩略图 /thumbs/{category}.svg，无分类则 /thumbs/blank.svg，再按下方规则解析
 * - 以 http:// 或 https:// 开头：原样返回（绝对地址）
 * - 其他（相对路径或 /images、/thumbs 等）：
 *   - /images、/thumbs：始终走站内同源资源，减少列表页的跨域图片请求
 *   - 其余相对路径：开发环境走站内路径；生产环境若配置 CDN 则拼接完整地址
 *
 * @returns 用于 <img src> 的完整或相对 URL
 */
const buildCoverSrc = (): string | undefined => {
  const resolveLocalSrc = (src: string): string => {
    const normalizedSrc = src.startsWith("/") ? src : `/${src}`;

    if (/^\/(images|thumbs)\//.test(normalizedSrc)) {
      return normalizedSrc;
    }

    if (import.meta.env.DEV) {
      return normalizedSrc;
    }

    const imagesBase = (SITE.imageConfig.imagesUrl ?? "")
      .trim()
      .replace(/\/$/, "");
    return imagesBase ? `${imagesBase}${normalizedSrc}` : normalizedSrc;
  };

  const rawImage = typeof cover === "string" ? cover.trim() : "";

  if (rawImage) {
    if (rawImage.startsWith("http://") || rawImage.startsWith("https://")) {
      return rawImage;
    }
    return resolveLocalSrc(rawImage);
  }

  const firstCategory = Array.isArray(categories) ? categories[0] : undefined;
  const filename = firstCategory || "blank";
  return resolveLocalSrc(`/thumbs/${filename}.svg`);
};

const coverSrc = buildCoverSrc();
---

<li class:list={["post-item", itemClass, { hidden }]}>
  <div class="post-item-inner">
    {
      coverSrc && (
        <div class="post-item-cover">
          <img
            src={coverSrc}
            alt={title}
            loading={
              priority
                ? "eager"
                : SITE.imageConfig.loading.lazy
                  ? "lazy"
                  : "eager"
            }
            fetchpriority={priority ? "high" : undefined}
            decoding="async"
          />
        </div>
      )
    }
    <div class="post-item-content">
      <div class="post-item-title-wrap">
        {
          variant === "h2" ? (
            <h2 class="post-item-title">
              <a href={PostUtils.getPath(id, filePath, true, date, timezone)}>
                {title}
              </a>
            </h2>
          ) : (
            <h3 class="post-item-title">
              <a href={PostUtils.getPath(id, filePath, true, date, timezone)}>
                {title}
              </a>
            </h3>
          )
        }
      </div>
      <div class="post-item-meta">
        <Datetime
          pubDatetime={date}
          modDatetime={updated}
          {timezone}
          format={dateFormat}
        />
        {
          primaryCategoryLabel && (
            <>
              <span class="post-item-meta-separator" aria-hidden="true">
                ·
              </span>
              <a
                href={`/categories/${primaryCategorySlug}`}
                class="post-item-category"
              >
                {primaryCategoryLabel}
              </a>
            </>
          )
        }
      </div>
    </div>
  </div>
</li>
