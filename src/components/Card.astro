---
import type { CollectionEntry } from "astro:content";
import { getCategoryMeta, PostUtils, slugifyStr } from "@/utils/postUtils";
import Datetime from "./Datetime.astro";
import { SITE } from "@/config";
import { formatFeedDate } from "@/utils/feedDate";

/**
 * 组件属性接口
 *
 * 扩展自 CollectionEntry<"blog">，包含文章的所有元数据
 *
 * @property variant - 标题级别（h2 或 h3）
 * @property itemClass - 额外的 CSS 类名
 * @property hidden - 是否隐藏此卡片
 * @property dateFormat - 日期显示格式：relative（相对时间）或 absolute（绝对时间 YYYY-MM-DD）
 * @property priority - 是否为 LCP 优先资源（首屏首图时设为 true，使用 fetchpriority="high"）
 * @property listKind - article：时间+分类链接；weekly：再加描述行；邻居订阅用 mode="feed"
 */
interface BlogCardProps extends CollectionEntry<"blog"> {
  mode?: "post";
  variant?: "h2" | "h3";
  listKind?: "article" | "weekly";
  itemClass?: string;
  hidden?: boolean;
  dateFormat?: "relative" | "absolute";
  priority?: boolean;
}

interface FeedCardProps {
  mode: "feed";
  title: string;
  link: string;
  published: string;
  blogName?: string;
  avatar?: string;
}

export type Props = BlogCardProps | FeedCardProps;

const rawProps = Astro.props as Props;
const isFeedCard = rawProps.mode === "feed";

const blogProps = rawProps as BlogCardProps;
const feedProps = rawProps as FeedCardProps;

const variant = !isFeedCard ? (blogProps.variant ?? "h2") : "h3";
const listKind = !isFeedCard ? (blogProps.listKind ?? "article") : "feed";
const itemClass = !isFeedCard ? blogProps.itemClass : undefined;
const hidden = !isFeedCard ? (blogProps.hidden ?? false) : false;
const dateFormat = !isFeedCard
  ? (blogProps.dateFormat ?? "relative")
  : "relative";
const priority = !isFeedCard ? (blogProps.priority ?? false) : false;

const data = !isFeedCard ? blogProps.data : undefined;
const id = !isFeedCard ? blogProps.id : undefined;
const filePath = !isFeedCard ? blogProps.filePath : undefined;

const title = isFeedCard ? feedProps.title : data!.title;
const date = !isFeedCard ? data!.date : undefined;
const updated = !isFeedCard ? data!.updated : undefined;
const timezone = !isFeedCard ? data!.timezone : undefined;
const cover = !isFeedCard ? data!.cover : undefined;
const categories = !isFeedCard ? data!.categories : undefined;
const primaryCategory = Array.isArray(categories) ? categories[0] : undefined;
const primaryCategoryLabel =
  getCategoryMeta(primaryCategory)?.name ?? primaryCategory;
const primaryCategorySlug = primaryCategory
  ? slugifyStr(primaryCategory)
  : undefined;

/**
 * 构建封面图 URL
 *
 * - cover 为空：取首个分类对应缩略图 /thumbs/{category}.svg，无分类则 /thumbs/blank.svg，再按下方规则解析
 * - 以 http:// 或 https:// 开头：原样返回（绝对地址）
 * - 其他（相对路径或 /images、/thumbs 等）：
 *   - /images、/thumbs：始终走站内同源资源，减少列表页的跨域图片请求
 *   - 其余相对路径：开发环境走站内路径；生产环境若配置 CDN 则拼接完整地址
 *
 * @returns 用于 <img src> 的完整或相对 URL
 */
const buildCoverSrc = (): string | undefined => {
  if (isFeedCard) return undefined;

  const resolveLocalSrc = (src: string): string => {
    const normalizedSrc = src.startsWith("/") ? src : `/${src}`;

    if (/^\/(images|thumbs)\//.test(normalizedSrc)) {
      return normalizedSrc;
    }

    if (import.meta.env.DEV) {
      return normalizedSrc;
    }

    const imagesBase = (SITE.imageConfig.imagesUrl ?? "")
      .trim()
      .replace(/\/$/, "");
    return imagesBase ? `${imagesBase}${normalizedSrc}` : normalizedSrc;
  };

  const rawImage = typeof cover === "string" ? cover.trim() : "";

  if (rawImage) {
    if (rawImage.startsWith("http://") || rawImage.startsWith("https://")) {
      return rawImage;
    }
    return resolveLocalSrc(rawImage);
  }

  const firstCategory = Array.isArray(categories) ? categories[0] : undefined;
  const filename = firstCategory || "blank";
  return resolveLocalSrc(`/thumbs/${filename}.svg`);
};

const coverSrc = buildCoverSrc();

const weeklyDescription =
  !isFeedCard && listKind === "weekly"
    ? (
        data!.description?.trim() ||
        PostUtils.getDescription(blogProps.body ?? "")
      ).trim()
    : "";

const feedDate = isFeedCard ? formatFeedDate(feedProps.published) : "";
const feedBlogName = isFeedCard ? (feedProps.blogName?.trim() ?? "") : "";

let avatarSrc = "";
if (isFeedCard) {
  avatarSrc = feedProps.avatar?.trim() || SITE.feeds.fallbackAvatarUrl || "";
  if (
    avatarSrc &&
    !/^https?:\/\//.test(avatarSrc) &&
    !avatarSrc.startsWith("//")
  ) {
    const avatarHost =
      (SITE.feeds.cosHost && SITE.feeds.cosHost.trim()) || SITE.website;
    avatarSrc =
      avatarHost.replace(/\/$/, "") +
      (avatarSrc.startsWith("/") ? avatarSrc : `/${avatarSrc}`);
  }
}
---

<li class:list={["post-item", itemClass, { hidden }]}>
  <div class="post-item-inner">
    {
      isFeedCard
        ? avatarSrc && (
            <div class="post-item-cover post-item-cover--avatar">
              <img
                src={avatarSrc}
                alt=""
                width={40}
                height={40}
                loading={priority ? "eager" : "lazy"}
                fetchpriority={priority ? "high" : undefined}
                decoding="async"
              />
            </div>
          )
        : coverSrc && (
            <div class="post-item-cover">
              <img
                src={coverSrc}
                alt={title}
                width={40}
                height={40}
                loading={
                  priority
                    ? "eager"
                    : SITE.imageConfig.loading.lazy
                      ? "lazy"
                      : "eager"
                }
                fetchpriority={priority ? "high" : undefined}
                decoding="async"
              />
            </div>
          )
    }
    <div class="post-item-content">
      <div class="post-item-title-wrap">
        {
          isFeedCard ? (
            <h3 class="post-item-title">
              {feedProps.link && feedProps.link !== "#" ? (
                <a
                  href={feedProps.link}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {title || "无标题"}
                </a>
              ) : (
                <span>{title || "无标题"}</span>
              )}
            </h3>
          ) : variant === "h2" ? (
            <h2 class="post-item-title">
              <a
                href={PostUtils.getPath(id!, filePath!, true, date!, timezone)}
              >
                {title}
              </a>
            </h2>
          ) : (
            <h3 class="post-item-title">
              <a
                href={PostUtils.getPath(id!, filePath!, true, date!, timezone)}
              >
                {title}
              </a>
            </h3>
          )
        }
      </div>
      {
        isFeedCard ? (
          <div class="post-item-meta">
            <span data-feed-published={feedProps.published}>{feedDate}</span>
            {feedBlogName && (
              <>
                <span class="post-item-meta-separator" aria-hidden="true">
                  ·
                </span>
                <span>{feedBlogName}</span>
              </>
            )}
          </div>
        ) : (
          <>
            {listKind !== "weekly" && (
              <div class="post-item-meta">
                <Datetime
                  class="post-item-datetime"
                  pubDatetime={date!}
                  modDatetime={updated}
                  {timezone}
                  format={dateFormat}
                />
                {primaryCategoryLabel && (
                  <>
                    <span class="post-item-meta-separator" aria-hidden="true">
                      ·
                    </span>
                    <a
                      href={`/categories/${primaryCategorySlug}`}
                      class="post-item-category"
                    >
                      {primaryCategoryLabel}
                    </a>
                  </>
                )}
              </div>
            )}
            {listKind === "weekly" && weeklyDescription && (
              <p class="post-item-description">{weeklyDescription}</p>
            )}
          </>
        )
      }
    </div>
  </div>
</li>

<style is:global>
  .post-item {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item.hidden {
    display: none;
  }

  .post-item-inner {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    padding: 0.06rem 0.28rem;
    border: none;
    border-radius: 0;
    background: transparent;
    transition: background-color 0.2s ease;
    /* 仅控制 .post-item-inner 最小高度；内容超出仍会自然撑高 */
    min-height: calc(0.8rem * 1.2 * 2 + 0.7rem * 1.3 * 2);
  }

  .post-item-inner:hover {
    background: color-mix(in srgb, var(--accent) 4%, transparent);
  }

  .post-item-cover {
    flex-shrink: 0;
    width: 40px;
  }

  .post-item-cover:not(.post-item-cover--avatar) img {
    aspect-ratio: 1;
    object-fit: cover;
  }

  .post-item-cover img {
    width: 100%;
    border-radius: 4px;
    display: block;
  }

  .post-item-cover--avatar img {
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  .post-item-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0;
  }

  .post-item :where(ul, ol, menu) {
    padding-left: 0;
  }

  .post-item-title {
    margin: 0 0 0.08rem;
    font-size: 0.875rem;
    line-height: 1.28;
    color: var(--text-primary);
    overflow-wrap: break-word;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }

  .post-item-title a {
    color: var(--accent);
    text-decoration: none;
  }

  .post-item-title a:hover {
    color: var(--accent-dark);
    text-decoration: underline;
  }

  .post-item-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.15rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .post-item-meta .post-item-datetime {
    display: inline-flex;
    align-items: center;
  }

  /* Datetime 内 time 带 text-sm，与 meta 统一为同一字号 */
  .post-item-meta :is(time, span, a) {
    font-size: inherit;
    line-height: inherit;
  }

  .post-item-category {
    color: var(--accent);
    text-decoration: none;
  }

  .post-item-category:hover {
    text-decoration: underline;
  }

  .post-item-description {
    margin: 0.16rem 0 0;
    font-size: 0.8125rem;
    line-height: 1.42;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }
</style>
