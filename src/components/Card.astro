---
import type { BlogLikeEntry } from "@/utils/contentCollections";
import { formatFeedDate, PostUtils, trimUrlSegment } from "@/utils/postUtils";
import Datetime from "./Datetime.astro";
import { SITE } from "@/config";
import { siteImageHref } from "@/utils/blogImages";

/**
 * 组件属性接口
 *
 * 扩展自 {@link BlogLikeEntry}，包含文章的所有元数据
 *
 * @property openInNewTab - 标题链接是否新标签打开（默认 true）
 * @property itemClass - 额外的 CSS 类名
 * @property hidden - 是否隐藏此卡片
 * @property dateFormat - 日期显示格式：relative（相对时间）或 absolute（绝对时间 YYYY-MM-DD）
 * @property listKind - article：时间行；weekly：再加描述行；邻居订阅用 mode="feed"
 */
type BlogCardProps = BlogLikeEntry & {
  mode?: "post";
  openInNewTab?: boolean;
  listKind?: "article" | "weekly";
  itemClass?: string;
  hidden?: boolean;
  dateFormat?: "relative" | "absolute";
};

interface FeedCardProps {
  mode: "feed";
  title: string;
  link: string;
  published: string;
  blogName?: string;
  avatar?: string;
}

export type Props = BlogCardProps | FeedCardProps;

const rawProps = Astro.props as Props;
const isFeedCard = rawProps.mode === "feed";

const blogProps = rawProps as BlogCardProps;
const feedProps = rawProps as FeedCardProps;

const openInNewTab = !isFeedCard ? (blogProps.openInNewTab ?? true) : false;
const listKind = !isFeedCard ? (blogProps.listKind ?? "article") : "feed";
const itemClass = !isFeedCard ? blogProps.itemClass : undefined;
const hidden = !isFeedCard ? (blogProps.hidden ?? false) : false;
const dateFormat = !isFeedCard
  ? (blogProps.dateFormat ?? "relative")
  : "relative";
const data = !isFeedCard ? blogProps.data : undefined;
const id = !isFeedCard ? blogProps.id : undefined;
const filePath = !isFeedCard ? blogProps.filePath : undefined;
const collection = !isFeedCard ? blogProps.collection : undefined;

const title = isFeedCard ? feedProps.title : data!.title;
const date = !isFeedCard ? data!.date : undefined;
const updated = !isFeedCard ? data!.updated : undefined;
const timezone = !isFeedCard ? data!.timezone : undefined;
const listFavicon = !isFeedCard ? data!.favicon : undefined;
const tagList = !isFeedCard ? (data!.tags ?? []) : [];

/**
 * 构建列表卡片 favicon URL（`public/images/_favicons/`）
 *
 * - favicon 为空：取首个标签对应图标 `/images/_favicons/{tag}.svg`（跳过 Others），无则 .../blank.svg
 * - 以 http(s):// 开头：原样
 * - 以 / 开头：根相对路径；同源 `/images/` 走站内
 * - 仅文件名：见 PostUtils.resolveFaviconRef
 *
 * @returns 用于 <img src> 的完整或相对 URL
 */
const buildListFaviconSrc = (): string | undefined => {
  if (isFeedCard) return undefined;

  const resolveLocalSrc = (src: string): string =>
    siteImageHref(src.startsWith("/") ? src : `/${src}`);

  const rawImage = typeof listFavicon === "string" ? listFavicon.trim() : "";

  if (rawImage) {
    if (rawImage.startsWith("http://") || rawImage.startsWith("https://")) {
      return rawImage;
    }
    const resolved = PostUtils.resolveFaviconRef(rawImage) ?? rawImage;
    return resolveLocalSrc(resolved);
  }

  const firstTagForIcon =
    tagList.find(t => trimUrlSegment(t) !== "Others") ?? tagList[0];
  const filename = firstTagForIcon ? trimUrlSegment(firstTagForIcon) : "blank";
  return resolveLocalSrc(`/images/_favicons/${filename}.svg`);
};

const listFaviconSrc = buildListFaviconSrc();

const weeklyDescription =
  !isFeedCard && listKind === "weekly"
    ? (
        data!.description?.trim() ||
        PostUtils.getDescription(blogProps.body ?? "")
      ).trim()
    : "";

const feedDate = isFeedCard ? formatFeedDate(feedProps.published) : "";
const feedBlogName = isFeedCard ? (feedProps.blogName?.trim() ?? "") : "";

let avatarSrc = "";
if (isFeedCard) {
  avatarSrc = feedProps.avatar?.trim() || SITE.feeds.fallbackAvatarUrl || "";
  if (
    avatarSrc &&
    !/^https?:\/\//.test(avatarSrc) &&
    !avatarSrc.startsWith("//")
  ) {
    if (!avatarSrc.startsWith("/images/")) {
      const name = avatarSrc.replace(/^\//, "");
      avatarSrc = `/images/_favicons/${name}`;
    }
    avatarSrc = siteImageHref(avatarSrc);
  }
}
---

<li
  class:list={[
    "pcard",
    itemClass,
    {
      hidden,
      "pcard--feed": isFeedCard,
      "pcard--weekly": !isFeedCard && listKind === "weekly",
      "pcard--article": !isFeedCard && listKind !== "weekly",
    },
  ]}
>
  <div class="pcard-inner">
    {
      isFeedCard
        ? avatarSrc && (
            <img
              src={avatarSrc}
              alt=""
              width={46}
              height={46}
              loading="lazy"
              decoding="async"
            />
          )
        : listFaviconSrc && (
            <img
              src={listFaviconSrc}
              alt={title}
              width={46}
              height={46}
              loading="lazy"
              decoding="async"
            />
          )
    }
    <div class="pcard-body">
      {
        isFeedCard ? (
          <p class="pcard-title">
            {feedProps.link && feedProps.link !== "#" ? (
              <a
                href={feedProps.link}
                target="_blank"
                rel="noopener noreferrer"
              >
                {title || "无标题"}
              </a>
            ) : (
              <span>{title || "无标题"}</span>
            )}
          </p>
        ) : (
          <p class="pcard-title">
            <a
              href={PostUtils.getPath(
                id!,
                filePath!,
                true,
                date!,
                timezone,
                data?.slug,
                collection!
              )}
              target={openInNewTab ? "_blank" : undefined}
              rel={openInNewTab ? "noopener noreferrer" : undefined}
            >
              {title}
            </a>
          </p>
        )
      }
      {
        isFeedCard ? (
          <div class="pcard-meta">
            <span data-feed-published={feedProps.published}>{feedDate}</span>
            {feedBlogName && (
              <>
                <span aria-hidden="true">·</span>
                <span>{feedBlogName}</span>
              </>
            )}
          </div>
        ) : (
          <>
            {listKind !== "weekly" && (
              <div class="pcard-meta">
                <Datetime
                  pubDatetime={date!}
                  modDatetime={updated}
                  {timezone}
                  format={dateFormat}
                />
              </div>
            )}
            {listKind === "weekly" && (
              <>
                {weeklyDescription && (
                  <p class="pcard-desc">{weeklyDescription}</p>
                )}
              </>
            )}
          </>
        )
      }
    </div>
  </div>
</li>

<style is:global>
  .pcard {
    --pcard-thumb-size: 44px;
    --pcard-padding-y: 0.2rem;
    --pcard-title-size: 0.86rem;
    --pcard-title-line-height: 1.34;
    --pcard-title-lines: 2;
    --pcard-title-gap: 0.12rem;
    --pcard-meta-size: var(--text-sm);
    --pcard-meta-line-height: 1.34;
  }

  .pcard {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pcard.hidden {
    display: none;
  }

  .pcard-inner {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    border: none;
    border-radius: 8px;
    background: transparent;
    padding: var(--pcard-padding-y) 0;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
    min-height: max(
      calc(var(--pcard-thumb-size) + var(--pcard-padding-y) * 2),
      calc(
        var(--pcard-title-size) * var(--pcard-title-line-height) *
          var(--pcard-title-lines) + var(--pcard-title-gap) +
          var(--pcard-meta-size) * var(--pcard-meta-line-height) +
          var(--pcard-padding-y) * 2
      )
    );
  }

  .pcard-inner:hover {
    background: color-mix(in srgb, var(--accent) 3%, transparent);
    transform: translateY(-1px);
  }

  .pcard-inner > img {
    width: var(--pcard-thumb-size);
    min-width: var(--pcard-thumb-size);
    max-width: none;
    height: var(--pcard-thumb-size);
    flex: 0 0 var(--pcard-thumb-size);
    flex-shrink: 0;
    align-self: flex-start;
    display: block;
    border-radius: 10px;
    object-fit: cover;
  }

  .pcard-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0;
  }

  .pcard :where(ul, ol, menu) {
    padding-left: 0;
  }

  .pcard-title {
    margin: 0 0 var(--pcard-title-gap);
    font-size: var(--pcard-title-size);
    line-height: var(--pcard-title-line-height);
    color: var(--text-primary);
    overflow-wrap: break-word;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }

  .pcard-title a {
    color: var(--accent);
    text-decoration: none;
  }

  .pcard-title a:hover {
    color: var(--accent-dark);
    text-decoration: underline;
  }

  .pcard--article .pcard-inner {
    padding-top: 0.28rem;
    padding-bottom: 0.28rem;
    gap: 0.5rem;
    min-height: max(
      calc(var(--pcard-thumb-size) + 1rem),
      calc(
        var(--pcard-title-size) * var(--pcard-title-line-height) *
          var(--pcard-title-lines) + var(--pcard-meta-size) *
          var(--pcard-meta-line-height) + 0.5rem
      )
    );
  }

  .pcard--article .pcard-title {
    margin-bottom: 0.08rem;
    line-height: 1.36;
  }

  .pcard--article .pcard-meta {
    line-height: 1.36;
  }

  .pcard--weekly .pcard-title {
    margin-bottom: 0.12rem;
  }

  .pcard-meta {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.18rem;
    min-width: 0;
    font-size: var(--pcard-meta-size);
    line-height: var(--pcard-meta-line-height);
    color: var(--text-secondary);
    overflow: hidden;
    white-space: nowrap;
  }

  /* 日期由 Datetime 自持字号；分隔符与分类链继承 meta */
  .pcard-meta :is(span, a) {
    font-size: inherit;
    line-height: inherit;
  }

  .pcard-meta > :first-child {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .pcard-meta > :not(:first-child):not([aria-hidden="true"]) {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pcard-meta a {
    display: inline-block;
    min-width: 0;
    max-width: 100%;
    color: var(--accent);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pcard-meta a:hover {
    text-decoration: underline;
  }

  .pcard--weekly .pcard-meta {
    font-size: 0.76rem;
    color: color-mix(in srgb, var(--text-secondary) 92%, var(--text-primary));
  }

  .pcard-desc {
    margin: 0.14rem 0 0;
    font-size: 0.83rem;
    line-height: 1.42;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }

  .pcard--weekly .pcard-desc {
    margin-top: 0.14rem;
    font-size: 0.83rem;
    line-height: 1.48;
    color: color-mix(in srgb, var(--text-secondary) 88%, var(--text-primary));
    -webkit-line-clamp: 1;
    line-clamp: 1;
  }

  .pcard-meta > [aria-hidden="true"] {
    flex: 0 0 auto;
    opacity: 0.6;
  }

  /* 包裹 Card 的列表（含首页 section > div > ul 等嵌套，主选择器匹配不到） */
  .post-cards-list {
    list-style: none;
    margin: 0;
    padding: 0;
    padding-inline-start: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media (max-width: 640px) {
    .pcard {
      --pcard-thumb-size: 40px;
      --pcard-padding-y: 0.22rem;
      --pcard-title-size: 0.83rem;
      --pcard-title-gap: 0.14rem;
    }

    .pcard-inner {
      gap: 0.6rem;
    }

    .pcard-inner > img {
      flex-shrink: 0;
      border-radius: 9px;
    }

    .pcard-title {
      line-height: 1.35;
    }

    .pcard-meta {
      line-height: 1.35;
    }

    .pcard--article .pcard-inner {
      gap: 0.52rem;
      padding-top: 0.3rem;
      padding-bottom: 0.3rem;
    }

    .pcard-desc {
      margin-top: 0.16rem;
      line-height: 1.5;
    }

    .pcard--weekly .pcard-desc {
      -webkit-line-clamp: 2;
      line-clamp: 2;
    }

    .post-cards-list {
      gap: 0;
    }
  }
</style>
