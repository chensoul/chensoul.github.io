---
/**
 * 订阅条目卡片组件
 *
 * @fileoverview 与 Card 组件结构一致：单条 RSS 聚合项（头像、标题、元信息）。
 * 用于订阅页列表，可与 feeds.js 客户端追加的 HTML 结构保持一致。
 */

import { formatFeedDate } from "@/utils/feedDate";
import { SITE } from "@/config";

export interface Props {
  title: string;
  link: string;
  published: string;
  blogName?: string;
  category?: string;
  avatar?: string;
  /** 首屏项可用 priority 以优先加载头像 */
  priority?: boolean;
}

const {
  title,
  link,
  published,
  blogName = "",
  category = "",
  avatar = "",
  priority = false,
} = Astro.props;

const displayDate = formatFeedDate(published);

let avatarSrc = avatar.trim() || SITE.feeds.fallbackAvatarUrl || "";
if (
  avatarSrc &&
  !/^https?:\/\//.test(avatarSrc) &&
  !avatarSrc.startsWith("//")
) {
  const avatarHost =
    (SITE.feeds.cosHost && SITE.feeds.cosHost.trim()) || SITE.website;
  avatarSrc =
    avatarHost.replace(/\/$/, "") +
    (avatarSrc.startsWith("/") ? avatarSrc : "/" + avatarSrc);
}
const hasLink = link && link !== "#";

const headerProps = {
  class: "feeds-card-header",
};
const linkProps = {
  class: "feeds-card-link",
};
---

<li class="feeds-card-wrapper">
  <div class="relative block">
    <div class="feeds-card">
      {
        avatarSrc && (
          <div class="feeds-card-avatar-wrap">
            <img
              src={avatarSrc}
              alt=""
              width={40}
              height={40}
              loading={priority ? "eager" : "lazy"}
              fetchpriority={priority ? "high" : undefined}
              decoding="async"
              class="feeds-card-avatar"
            />
          </div>
        )
      }
      <div class="feeds-card-content">
        <div class="feeds-card-title-wrap">
          <h3 {...headerProps}>
            {
              hasLink ? (
                <a
                  href={link}
                  {...linkProps}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {title || "无标题"}
                </a>
              ) : (
                <span class="feeds-card-title-text">{title || "无标题"}</span>
              )
            }
          </h3>
        </div>
        <div class="feeds-card-meta">
          <span class="feeds-card-date" data-published={published}>
            {displayDate}
          </span>
          {blogName.trim() ? " · " + blogName.trim() : ""}
          {category.trim() ? " · " + category.trim() : ""}
        </div>
      </div>
    </div>
  </div>
</li>
