---
import "photosuite/dist/photosuite.css";
---

<style is:global>
  /**
   * Photosuite 对 img 写了 margin:0 !important，会盖掉 base.css 里用 margin:auto 的居中。
   * 在容器上居中；拼图内的 .photosuite-grid-member 由套件自己排版，不套这条。
   */
  #main-content .post-content
    .photosuite-item:not(.photosuite-grid-member) {
    display: block;
    width: fit-content;
    max-width: 70%;
    margin-left: auto;
    margin-right: auto;
    margin-block: 1rem;
  }

  @media (max-width: 768px) {
    #main-content .post-content
      .photosuite-item:not(.photosuite-grid-member) {
      max-width: 100%;
    }
  }

  /* 覆盖正文 img 的 max-width:80%，使图宽与 .photosuite-item / caption 一致 */
  #main-content .post-content .photosuite-item img {
    max-width: 100%;
    border-radius: 8px !important;
  }
</style>
