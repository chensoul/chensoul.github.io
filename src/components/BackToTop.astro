---
import IconChevronUp from "@/assets/icons/IconChevronUp.svg";

export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<button
  id="back-to-top"
  aria-label="返回顶部"
  class:list={["back-to-top-btn", className]}
  data-scroll-threshold="300"
>
  <IconChevronUp />
</button>

<script is:inline data-astro-rerun>
  (function () {
    const btn = document.getElementById("back-to-top");
    const scrollThreshold = Number(btn?.dataset.scrollThreshold) || 300;

    if (!btn) return;

    // 初始状态：隐藏
    btn.classList.add("back-to-top-btn--hidden");

    function updateVisibility() {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const shouldShow = scrollTop >= scrollThreshold;

      btn.classList.toggle("back-to-top-btn--hidden", !shouldShow);
      btn.classList.toggle("back-to-top-btn--visible", shouldShow);
    }

    // 使用 requestAnimationFrame 优化滚动性能
    let ticking = false;
    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateVisibility();
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    updateVisibility();

    // 点击平滑滚动到顶部
    btn.addEventListener("click", () => {
      window.scrollTo({
        top: 0,
        behavior: "smooth",
      });
    });
  })();
</script>
