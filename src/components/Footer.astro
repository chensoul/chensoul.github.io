---
/**
 * 页脚组件
 *
 * @fileoverview 参考 zdyxry.github.io Footer：社交图标区 + 版权/备案/自定义链接
 * @see https://github.com/zdyxry/zdyxry.github.io/blob/astro/src/components/Footer.astro
 */

import { SITE } from "@/config";
import SocialIcon from "@/components/SocialIcon.astro";

export interface Props {
  /** 是否移除顶部外边距 */
  noMarginTop?: boolean;
  /** 是否显示社交链接区 */
  showSocial?: boolean;
}

const currentYear = new Date().getFullYear();
const { noMarginTop = false, showSocial = true } = Astro.props;

const socialLinks = SITE.socialLinks ?? [];
const hasSocial = showSocial && socialLinks.length > 0;

/** 规范化链接：若为邮箱地址则补全 mailto:，避免被当作相对路径 */
function normalizeSocialHref(url: string): string {
  if (url.startsWith("mailto:") || url.startsWith("http")) return url;
  if (url.includes("@")) return `mailto:${url}`;
  return url;
}
---

<footer class:list={["footer", "w-full", { "mt-auto": !noMarginTop }]}>
  <div class="footer-content">
    <hr class="footer-hr" aria-hidden="true" />
    {
      hasSocial && (
        <div class="social-links">
          {socialLinks.map(link => {
            const href = normalizeSocialHref(link.url);
            const isExternal = href.startsWith("http");
            return (
              <a
                href={href}
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
                aria-label={link.name}
              >
                <SocialIcon name={link.icon} width={20} height={20} />
              </a>
            );
          })}
        </div>
      )
    }
    <div class="footer-bottom">
      <span class="copyright">
        &#169; {currentYear}
        {SITE.author}. All rights reserved.
      </span>
      {
        SITE.icp && (
          <>
            <span class="separator" aria-hidden="true">
              |
            </span>
            <a
              href="https://beian.miit.gov.cn/"
              target="_blank"
              rel="noopener noreferrer"
            >
              备案号 {SITE.icp}
            </a>
          </>
        )
      }
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--background);
    padding: 1rem 0 1.5rem;
  }

  .footer-hr {
    width: 100%;
    margin: 1rem 0 1rem 0;
    border: 0;
    border-top: 1px solid var(--border);
  }

  .footer-content {
    max-width: var(--page-max-width);
    margin: 0 auto;
    padding: 0 var(--content-gutter);
    text-align: center;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .social-links a {
    color: var(--text-secondary);
    padding: 0.4rem;
    border-radius: 999px;
    background: transparent;
    border: 1px solid transparent;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .social-links a:hover,
  .social-links a:focus-visible {
    color: var(--accent);
    text-decoration: none;
    border-color: var(--border);
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.25rem 0.5rem;
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .footer-bottom .copyright {
    white-space: nowrap;
  }

  .footer-bottom .separator {
    opacity: 0.7;
  }

  .footer-bottom a {
    color: var(--accent);
    text-decoration: none;
  }

  .footer-bottom a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .footer-bottom a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
