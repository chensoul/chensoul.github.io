---
/**
 * 文章目录（TOC）：从正文内已带 id 的 h2/h3 生成，与 rehype-slug 锚点一致。
 * 参考常见开发者文档（如 OpenAI Developers 博文侧栏/文内目录）的信息层级。
 */
---

<nav
  class="article-toc"
  id="article-toc"
  aria-label="本页目录"
  hidden
>
</nav>

<style is:global>
  .article-toc {
    margin: 0 0 1rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--background-secondary);
  }

  .article-toc__title {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .article-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .article-toc li {
    margin: 0.2rem 0;
    line-height: 1.35;
  }

  .article-toc li.article-toc__sub {
    padding-left: 0.85rem;
    border-left: 2px solid color-mix(in srgb, var(--border) 80%, transparent);
    margin-left: 0.15rem;
  }

  .article-toc__link {
    display: block;
    font-size: 0.8125rem;
    text-decoration: none;
    color: var(--text-secondary);
    border-radius: calc(var(--radius) - 2px);
    padding: 0.2rem 0.4rem;
    margin: 0 -0.4rem;
    transition:
      color 0.15s ease,
      background-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .article-toc__link:hover {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .article-toc__link.article-toc__link--active {
    color: var(--text-primary);
    font-weight: 600;
    background: var(--accent-surface);
    box-shadow: inset 3px 0 0 0 var(--accent);
    text-decoration: none;
  }

  .article-toc__link.article-toc__link--active:hover {
    text-decoration: none;
  }
</style>

<script>
  let articleTocCleanup: (() => void) | null = null;

  /**
   * 与浏览器锚点滚动一致：正文 h2/h3 的 scroll-margin-top（--site-header-sticky-offset）。
   * 勿用 header 实测高度代替，否则与 CSS 不一致时会出现「点了 A 却高亮 B」。
   */
  function tocStickyLinePx(headingSample: HTMLElement): number {
    const sm = getComputedStyle(headingSample).scrollMarginTop;
    const px = parseFloat(sm);
    if (!Number.isNaN(px) && px >= 0) return Math.round(px);
    const header = document.querySelector("body > header");
    if (header instanceof HTMLElement) {
      return Math.round(header.getBoundingClientRect().height + 6);
    }
    return 88;
  }

  /**
   * 是否已滚到文档末尾附近（距可滚尽头 marginPx 内）。
   * 可滚高度 ≤ marginPx 时不启用，避免短文/微滚动误把最后一项钉死。
   */
  function isScrolledToDocumentBottom(marginPx: number): boolean {
    const docEl = document.documentElement;
    const viewH = window.innerHeight;
    const docH = docEl.scrollHeight;
    const maxScroll = docH - viewH;
    if (maxScroll <= marginPx) return false;
    return window.scrollY >= maxScroll - marginPx;
  }

  function buildArticleToc() {
    articleTocCleanup?.();
    articleTocCleanup = null;

    const nav = document.getElementById("article-toc");
    const root = document.querySelector("#article .post-article-content");
    if (!nav || !root) return;

    nav.replaceChildren();
    nav.hidden = true;

    const hs = root.querySelectorAll("h2[id], h3[id]");
    if (hs.length < 2) return;

    const title = document.createElement("p");
    title.className = "article-toc__title";
    title.textContent = "目录";
    nav.appendChild(title);

    const headingEls = [...hs] as HTMLElement[];
    const linkById = new Map<string, HTMLAnchorElement>();

    const ul = document.createElement("ul");
    for (const h of headingEls) {
      const li = document.createElement("li");
      if (h.tagName === "H3") li.classList.add("article-toc__sub");
      const a = document.createElement("a");
      a.className = "article-toc__link";
      a.setAttribute("href", `#${h.id}`);
      a.textContent = (h.textContent ?? "").trim();
      linkById.set(h.id, a);
      li.appendChild(a);
      ul.appendChild(li);
    }
    nav.appendChild(ul);
    nav.hidden = false;

    function applyActiveTocId(activeId: string) {
      for (const [id, a] of linkById) {
        const on = id === activeId;
        a.classList.toggle("article-toc__link--active", on);
        if (on) a.setAttribute("aria-current", "location");
        else a.removeAttribute("aria-current");
      }
    }

    /** 由滚动位置推算当前应对应的目录 id（与 scroll-margin / 吸顶留白一致） */
    function computeActiveIdFromScroll(): string | null {
      const headings = headingEls;
      const first = headings[0];
      if (!first?.id) return null;

      const offset = tocStickyLinePx(first) + 2;
      let activeId = first.id;

      if (isScrolledToDocumentBottom(40)) {
        const last = headings[headings.length - 1];
        if (last?.id) activeId = last.id;
      } else {
        for (const h of headings) {
          if (h.getBoundingClientRect().top <= offset) activeId = h.id;
        }
        if (first.getBoundingClientRect().top > offset) activeId = first.id;
      }

      return activeId;
    }

    function syncActiveFromScrollPosition() {
      const id = computeActiveIdFromScroll();
      if (id) applyActiveTocId(id);
    }

    /**
     * 全站 html 使用 scroll-behavior: smooth，点目录时滚动过程中会多次触发 scroll，
     * 若每次都同步高亮，会在「动画中途」误判成别的章节。仅在滚动停顿后再算位置。
     */
    let scrollSyncTimer: number | null = null;
    function scheduleSyncFromScroll() {
      if (scrollSyncTimer != null) window.clearTimeout(scrollSyncTimer);
      scrollSyncTimer = window.setTimeout(() => {
        scrollSyncTimer = null;
        syncActiveFromScrollPosition();
      }, 80);
    }

    const tocEvents = new AbortController();
    const { signal } = tocEvents;

    window.addEventListener("scroll", scheduleSyncFromScroll, { passive: true, signal });
    window.addEventListener("resize", () => {
      if (scrollSyncTimer != null) {
        window.clearTimeout(scrollSyncTimer);
        scrollSyncTimer = null;
      }
      syncActiveFromScrollPosition();
    }, { signal });
    window.addEventListener("hashchange", scheduleSyncFromScroll, { signal });

    for (const h of headingEls) {
      const anchor = linkById.get(h.id);
      if (!anchor) continue;
      anchor.addEventListener(
        "click",
        () => {
          applyActiveTocId(h.id);
          scheduleSyncFromScroll();
        },
        { signal }
      );
    }

    articleTocCleanup = () => {
      if (scrollSyncTimer != null) {
        window.clearTimeout(scrollSyncTimer);
        scrollSyncTimer = null;
      }
      tocEvents.abort();
    };

    syncActiveFromScrollPosition();
    requestAnimationFrame(() => {
      requestAnimationFrame(syncActiveFromScrollPosition);
    });
    if (location.hash) {
      setTimeout(syncActiveFromScrollPosition, 120);
      setTimeout(syncActiveFromScrollPosition, 400);
    }
  }

  buildArticleToc();
  document.addEventListener("astro:page-load", buildArticleToc);
  document.addEventListener("astro:before-preparation", () => {
    articleTocCleanup?.();
    articleTocCleanup = null;
  });
</script>
