---
/**
 * 统一列表页骨架：页面标题、一句说明、下方卡片列表。
 * 用于博客 / 周报 / 译文 / Wiki 等「标题 + 描述 + post-cards-list」结构，收紧标题区与列表间距。
 */
export interface Props {
  /** 页面主标题（h1） */
  title: string;
  /** 标题下灰色说明；不传则只渲染标题 */
  description?: string;
}

const { title, description } = Astro.props;
---

<section
  class="list-layout w-full min-w-0"
  aria-labelledby="list-layout-heading"
>
  <header class="list-layout__head">
    <h1
      id="list-layout-heading"
      class="list-layout__title mt-0 text-3xl font-semibold tracking-tight"
    >
      {title}
    </h1>
    {
      description?.trim() && (
        <p class="list-layout__lead mt-1.5 mb-0 max-w-[65ch] text-sm leading-snug text-pretty text-muted">
          {description.trim()}
        </p>
      )
    }
  </header>
  <div class="list-layout__body">
    <slot />
  </div>
</section>

<style>
  /* 标题整块与列表的间距：略小于原 mt-2 mb-6，避免描述与首条卡片之间空白过大 */
  .list-layout__head {
    margin-bottom: 0.5rem;
  }

  @media (min-width: 768px) {
    .list-layout__head {
      margin-bottom: 0.625rem;
    }
  }
</style>
