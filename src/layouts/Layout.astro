---
/**
 * 全站基础布局
 *
 * @fileoverview 提供 HTML 骨架、meta/OG/JSON-LD、主题脚本、Header、Footer、BackToTop、BackButton；子页通过 props 传入 title、description、canonicalURL 等页面元信息。
 */
import { SITE } from "@/config";
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackToTop from "@/components/BackToTop.astro";
/**
 * 组件属性接口
 *
 * @property title - 页面标题，可不传；未传或为空时使用 SITE.title（网站名称）
 * @property author - 作者名称
 * @property description - 页面描述，可不传；未传或为空时使用 SITE.description（站点描述）
 * @property canonicalURL - 规范链接
 * @property pubDatetime - 发布时间
 * @property modDatetime - 更新时间
 * @property ogImage - 社交分享图：根相对路径（如 /images/x.webp）、或 https 绝对 URL；未传则用默认 OG
 */
export interface Props {
  title?: string;
  author?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  schemaType?: string;
  robots?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
}

// 解构属性，设置默认值（title 未传或为空时用网站名称）
const {
  title: titleProp,
  author = SITE.author,
  description: descriptionProp,
  ogImage: ogImageProp,
  canonicalURL = new URL(Astro.url.pathname.replace(/\.html?$/, ""), Astro.url),
  schemaType,
  robots,
  pubDatetime,
  modDatetime,
} = Astro.props;

const title = titleProp?.trim() || SITE.title;
const fullDescription = descriptionProp?.trim() || SITE.description;
const robotsContent = robots?.trim() || "index,follow";
const pathname = Astro.url.pathname.replace(/\.html?$/, "") || "/";
const hasAfterMain = Astro.slots.has("after-main");
const canonicalHref = String(canonicalURL);
const isArticlePage = Boolean(pubDatetime);
const isHomePage = pathname === "/";
const isCollectionPage =
  /^\/(posts|archives|categories|tags)(\/|$)/.test(pathname);
const ogType = isArticlePage ? "article" : "website";
const defaultSchemaType = isArticlePage
  ? "BlogPosting"
  : isHomePage
    ? "WebSite"
    : isCollectionPage
      ? "CollectionPage"
      : "WebPage";
const resolvedSchemaType = schemaType?.trim() || defaultSchemaType;

const ogEnabled = SITE.og.enabled;
const useDynamicOg = ogEnabled && SITE.og.dynamic;

/** 默认 OG 静态图：支持根相对路径或绝对 URL（与 SITE.og.defaultImage 一致） */
const normalizeStaticOgDefault = (p: string) => {
  const t = p.trim();
  if (!t) return "/images/og.webp";
  if (/^https?:\/\//i.test(t)) return t;
  return t.startsWith("/") ? t : `/${t}`;
};

const staticDefaultOgRef = normalizeStaticOgDefault(SITE.og.defaultImage);

const pathForOg = pathname.replace(/^\/+/, "").replace(/\/+$/, "");
const defaultOgFromUrl =
  pathname === "/" || pathForOg === ""
    ? "/og/index.png"
    : pathForOg.startsWith("posts/")
      ? `/og/${pathForOg.slice("posts/".length)}.png`
      : `/og/${pathForOg}.png`;

const defaultOgImage = useDynamicOg ? defaultOgFromUrl : staticDefaultOgRef;
const ogImage = ogImageProp ?? defaultOgImage;
/** 分享图绝对地址（根相对、站外绝对 URL 均支持） */
const socialImageURLString = (() => {
  if (!ogEnabled) return "";
  const ref = ogImage.trim();
  if (!ref) return new URL("images/og.webp", Astro.url.origin).href;
  if (/^https?:\/\//i.test(ref)) return ref;
  const path = ref.startsWith("/") ? ref : `/${ref}`;
  return new URL(path, Astro.url.origin).href;
})();
/** OG 图尺寸（与 utils/og-image.ts 生成一致） */
const OG_IMAGE_WIDTH = 1200;
const OG_IMAGE_HEIGHT = 630;

/**
 * 结构化数据（JSON-LD）
 *
 * 用于搜索引擎理解页面内容，提升 SEO 效果
 * @see https://schema.org/BlogPosting
 */
const structuredData = resolvedSchemaType === "BlogPosting"
  ? {
      "@context": "https://schema.org",
      "@type": resolvedSchemaType,
      headline: title,
      description: fullDescription,
      url: canonicalHref,
      mainEntityOfPage: canonicalHref,
      ...(ogEnabled ? { image: socialImageURLString } : {}),
      datePublished: pubDatetime?.toISOString(),
      ...(modDatetime && { dateModified: modDatetime.toISOString() }),
      author: [
        {
          "@type": "Person",
          name: author,
        },
      ],
      publisher: {
        "@type": "Organization",
        name: SITE.title,
        url: SITE.website,
      },
    }
  : resolvedSchemaType === "WebSite"
    ? {
        "@context": "https://schema.org",
        "@type": resolvedSchemaType,
        name: SITE.title,
        url: SITE.website,
        description: fullDescription,
        inLanguage: SITE.lang,
      }
    : {
        "@context": "https://schema.org",
        "@type": resolvedSchemaType,
        name: title,
        url: canonicalHref,
        description: fullDescription,
        isPartOf: {
          "@type": "WebSite",
          name: SITE.title,
          url: SITE.website,
        },
        inLanguage: SITE.lang,
      };
---

<!doctype html>
<html lang={SITE.lang} data-theme={SITE.lightAndDarkMode ? undefined : "light"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={fullDescription} />
    <meta name="author" content={author} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#ffffff" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={fullDescription} />
    <meta property="og:url" content={canonicalURL} />
    {
      ogEnabled && (
        <>
          <meta property="og:image" content={socialImageURLString} />
          <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
          <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
          <meta property="og:image:alt" content={title} />
        </>
      )
    }
    <meta property="og:locale" content={SITE.langOg} />
    <meta property="og:type" content={ogType} />

    <!-- Twitter Card -->
    <meta
      property="twitter:card"
      content={ogEnabled ? "summary_large_image" : "summary"}
    />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={fullDescription} />
    {
      ogEnabled && (
        <>
          <meta property="twitter:image" content={socialImageURLString} />
          <meta property="twitter:image:alt" content={title} />
        </>
      )
    }

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    {
      SITE.googleSiteVerification && (
        <meta
          name="google-site-verification"
          content={SITE.googleSiteVerification}
        />
      )
    }
    {
      SITE.bingSiteVerification && (
        <meta name="msvalidate.01" content={SITE.bingSiteVerification} />
      )
    }

    <!-- Theme initialization script to prevent flash；切换禁用时固定浅色 -->
    <script is:inline define:vars={{ lightAndDarkMode: SITE.lightAndDarkMode }}>
      (function () {
        const html = document.documentElement;

        function readStoredTheme() {
          try {
            return localStorage.getItem("theme");
          } catch {
            return null;
          }
        }

        function getTheme() {
          if (!lightAndDarkMode) return "light";

          const storedTheme = readStoredTheme();
          if (storedTheme === "light" || storedTheme === "dark") {
            return storedTheme;
          }

          if (
            window.matchMedia &&
            window.matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            return "dark";
          }

          return "light";
        }

        function setTheme(theme) {
          const nextTheme = theme === "dark" ? "dark" : "light";
          html.setAttribute("data-theme", nextTheme);
          if (lightAndDarkMode) {
            try {
              localStorage.setItem("theme", nextTheme);
            } catch {}
          }
          window.dispatchEvent(
            new CustomEvent("themechange", { detail: { theme: nextTheme } })
          );
          return nextTheme;
        }

        const initialTheme = setTheme(getTheme());

        window.__theme = {
          getTheme,
          setTheme,
          toggleTheme() {
            const currentTheme = html.getAttribute("data-theme") || initialTheme;
            return setTheme(currentTheme === "light" ? "dark" : "light");
          },
        };
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <a
      href="#main-content"
      class="skip-link"
    >
      跳转到主要内容
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    {hasAfterMain && <slot name="after-main" />}
    <BackToTop />
    <Footer/>

    <style is:global>
      .skip-link {
        position: absolute;
        top: -100%;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1000;
        background: var(--accent);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0 0 0.5rem 0.5rem;
        font-weight: 500;
        text-decoration: none;
        transition: top 0.2s ease;
      }

      .skip-link:focus-visible {
        top: 0;
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .breadcrumb {
        font-size: 0.875rem;
        color: var(--text-secondary);
        margin-bottom: 1rem;
      }

      .breadcrumb a {
        color: var(--text-secondary);
      }

      .breadcrumb a:hover {
        color: var(--accent);
      }

      .breadcrumb-separator {
        margin: 0 0.35rem;
        opacity: 0.6;
      }
    </style>

    {
      import.meta.env.PROD &&
      SITE.umami.enabled &&
      SITE.umami?.websiteId &&
      SITE.umami?.scriptUrl && (
        <script is:inline define:vars={{ websiteId: SITE.umami.websiteId, scriptUrl: SITE.umami.scriptUrl }}>
          (function () {
            if (!websiteId || !scriptUrl) return;
            let done = false;
            function load() {
              if (done) return;
              done = true;
              const s = document.createElement("script");
              s.src = scriptUrl;
              s.setAttribute("data-website-id", websiteId);
              s.defer = true;
              document.head.appendChild(s);
            }

            ["click", "keydown", "touchstart"].forEach((ev) =>
              window.addEventListener(ev, load, { once: true, passive: true })
            );
          })();
        </script>
      )
    }
  </body>
</html>
