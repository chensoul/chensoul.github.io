---
/**
 * 文章详情布局
 *
 * @fileoverview 渲染单篇文章：标题、元数据、正文（Content）、前后篇导航、标签列表，以及按 frontmatter 控制的评论/数学公式等功能。canonical 等元信息由本布局传给 Layout。
 */
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import Artalk from "@/components/Artalk.astro";
import Photosuite from "@/components/Photosuite.astro";
import ArticleToc from "@/components/ArticleToc.astro";
import TaxonomySummary from "@/components/TaxonomySummary.astro";
import { getCategoryMeta, PostUtils, slugifyStr } from "@/utils/postUtils";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import IconTag from "@/assets/icons/IconTag.svg";
import { SITE } from "@/config";

export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

// 解构文章元数据
const {
  title,
  author,
  canonicalURL,
  date,
  updated,
  tags,
  math,
  comments,
  description: postDescription,
  "top-image": topImageRaw,
  categories,
} = post.data;

/** 解析 top-image 的完整 URL：绝对地址原样返回，相对路径在生产环境拼接 CDN 前缀 */
const topImageSrc =
  topImageRaw && topImageRaw.trim()
    ? (() => {
        const src = topImageRaw.trim();
        if (src.startsWith("http://") || src.startsWith("https://")) return src;
        const normalized = src.startsWith("/") ? src : `/${src}`;
        if (import.meta.env.DEV) return normalized;
        const base = (SITE.imageConfig.imagesUrl ?? "")
          .trim()
          .replace(/\/$/, "");
        return base ? `${base}${normalized}` : normalized;
      })()
    : undefined;

// 渲染文章内容
const { Content } = await render(post);
const hasInlineImages = /!\[[\s\S]*?\]\([^)]+\)|<img\s/i.test(post.body ?? "");

/** 文章描述：优先 frontmatter description，否则从正文提取（与 RSS 摘要逻辑一致，不含 top-image） */
const fullDescription =
  postDescription?.trim() || PostUtils.getDescription(post.body ?? "");
const plainText = (post.body ?? "")
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/`[^`]*`/g, " ")
  .replace(/!\[[^\]]*]\([^)]+\)/g, " ")
  .replace(/\[[^\]]*]\([^)]+\)/g, " ")
  .replace(/<[^>]+>/g, " ")
  .replace(/[#>*_\-\n\r]/g, " ")
  .replace(/\s+/g, " ")
  .trim();
const latinWordCount = (
  plainText.match(/[A-Za-z0-9]+(?:['' -][A-Za-z0-9]+)*/g) || []
).length;
const cjkCharCount = (plainText.match(/[\u3400-\u9FFF]/g) || []).length;
const estimatedWordCount = latinWordCount + cjkCharCount;
const readingMinutes = Math.max(1, Math.ceil(estimatedWordCount / 300));
const primaryCategory = categories?.[0];
const primaryCategoryLabel =
  getCategoryMeta(primaryCategory)?.name ?? primaryCategory;
const categoryLinks = categories.map(category => ({
  name: getCategoryMeta(category)?.name ?? category,
  slug: slugifyStr(category),
}));
const breadcrumbItems = [
  { name: "首页", item: SITE.website },
  { name: "文章", item: new URL("/posts", SITE.website).toString() },
  ...(primaryCategory
    ? [
        {
          name: primaryCategoryLabel,
          item: new URL(
            `/categories/${slugifyStr(primaryCategory)}`,
            SITE.website
          ).toString(),
        },
      ]
    : []),
  { name: title, item: canonicalHrefPlaceholder() },
];

function canonicalHrefPlaceholder() {
  return "";
}

const layoutProps = {
  title,
  author,
  description: fullDescription,
  pubDatetime: date,
  modDatetime: updated,
  canonicalURL,
};

/* ========== Prev/Next Posts ========== */
const allPosts = posts.map(
  ({ data: { title, date, timezone }, id, filePath }) => ({
    path: PostUtils.getPath(id, filePath, true, date, timezone),
    title,
  })
);

const currentPostPath = PostUtils.getPath(
  post.id,
  post.filePath,
  true,
  post.data.date,
  post.data.timezone
);

const canonicalHref =
  canonicalURL != null
    ? String(canonicalURL)
    : new URL(currentPostPath, SITE.website).toString();
breadcrumbItems[breadcrumbItems.length - 1].item = canonicalHref;
const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.item,
  })),
};

const relatedPostLimit = 6;
const scoredRelatedPosts = posts
  .filter(candidate => candidate.id !== post.id)
  .map(candidate => {
    const sharedTags = candidate.data.tags.filter(tag =>
      tags.includes(tag)
    ).length;
    const sharedCategories = candidate.data.categories.filter(category =>
      post.data.categories.includes(category)
    ).length;
    const score = sharedCategories * 4 + sharedTags * 2;

    return {
      post: candidate,
      score,
      path: PostUtils.getPath(
        candidate.id,
        candidate.filePath,
        true,
        candidate.data.date,
        candidate.data.timezone
      ),
    };
  })
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;

    return (
      new Date(b.post.data.updated ?? b.post.data.date).getTime() -
      new Date(a.post.data.updated ?? a.post.data.date).getTime()
    );
  });

const relatedPosts = [
  ...scoredRelatedPosts.filter(item => item.score > 0),
  ...scoredRelatedPosts.filter(item => item.score === 0),
].slice(0, relatedPostLimit);

const shareText = `${title} | ${SITE.title}`;
const shareUrl = encodeURIComponent(canonicalHref);
const shareTitle = encodeURIComponent(shareText);
const shareDescription = encodeURIComponent(fullDescription);

const currentPostIndex = allPosts.findIndex(a => a.path === currentPostPath);

const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;

/** 预加载样式转正样式用，避免 TS 把 onload 属性内容当代码解析 */
const linkPreloadOnLoad = "this.onload=null;this.rel='stylesheet'";
---

<Layout {...layoutProps}>
  <TaxonomySummary items={[]} />
  {hasInlineImages && <Photosuite />}
  {
    tags.map((tag: string) => (
      <meta slot="head" property="article:tag" content={tag} />
    ))
  }
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbStructuredData)}
  />
  <!-- KaTeX 数学公式样式（仅文章详情且启用公式时加载） -->
  {
    math && (
      <link
        slot="head"
        rel="preload"
        href="https://cos.chensoul.cc/dist/katex/0.16.38/dist/katex.min.css"
        as="style"
        crossorigin="anonymous"
        referrerpolicy="no-referrer"
        onload={linkPreloadOnLoad}
      />
    )
  }
  {
    math && (
      <noscript slot="head">
        <link
          rel="stylesheet"
          href="https://cos.chensoul.cc/dist/katex/0.16.38/dist/katex.min.css"
          crossorigin="anonymous"
          referrerpolicy="no-referrer"
        />
      </noscript>
    )
  }

  <article id="article" data-pagefind-body>
    <header>
      {topImageSrc && <img src={topImageSrc} alt={title} />}

      <div class="breadcrumb" aria-label="面包屑导航">
        <a href="/">首页</a>
        <span class="breadcrumb-separator">/</span>
        <a href="/posts">文章</a>
        {
          primaryCategory && (
            <>
              <span class="breadcrumb-separator">/</span>
              <a href={`/categories/${slugifyStr(primaryCategory)}`}>
                {primaryCategoryLabel}
              </a>
            </>
          )
        }
      </div>

      <section class="article-header">
        <h1 class="article-title">
          {title}
        </h1>
        <div class="article-meta">
          {
            categoryLinks.map(category => (
              <a class="no-underline" href={`/categories/${category.slug}`}>
                {category.name}
              </a>
            ))
          }
          <span class="meta-separator" aria-hidden="true">·</span>
          <span class="reading-time">{readingMinutes} 分钟阅读</span>
          <span class="meta-separator" aria-hidden="true">·</span>
          <Datetime
            pubDatetime={date}
            modDatetime={updated}
            timezone={post.data.timezone}
            format="absolute"
          />
        </div>
      </section>
    </header>

    <div class="article-main-layout">
      <div class="post-article-body reading-content post-article-content">
        <Content />
      </div>
      <ArticleToc />
    </div>
  </article>

  <!-- 标签列表 -->
  {
    tags.length > 0 && (
      <div class="tags-section">
        <span class="tags-icon" aria-hidden="true">
          <IconTag />
        </span>
        <ul class="tags-list" role="list">
          {tags.map((tag: string) => (
            <Tag tag={slugifyStr(tag)} tagName={tag} />
          ))}
        </ul>
      </div>
    )
  }

  <section class="action-section">
    <div class="action-card">
      <p class="action-label">订阅文章</p>
      <h3>订阅更新，不错过后续文章</h3>
      <p class="action-description">直接通过 RSS 和 Telegram 订阅本站更新。</p>
      <div class="action-buttons">
        <a class="btn btn-primary" href="/rss.xml">订阅 RSS</a>
        <a class="btn btn-secondary" href="https://t.me/ichensoul"
          >关注 Telegram</a
        >
      </div>
    </div>

    <div class="action-card">
      <p class="action-label">分享文章</p>
      <h3>如果这篇有帮助，可以顺手转发</h3>
      <p class="action-description">
        直接分享给同事、朋友，或者发到你的社交平台。
      </p>
      <div class="action-buttons">
        <a
          class="btn btn-secondary"
          href={`https://x.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          分享到 X
        </a>
        <a
          class="btn btn-secondary"
          href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          分享到 Telegram
        </a>
        <a
          class="btn btn-secondary"
          href={`mailto:?subject=${shareTitle}&body=${shareDescription}%0A%0A${shareUrl}`}
        >
          邮件分享
        </a>
      </div>
    </div>
  </section>

  {
    relatedPosts.length > 0 && (
      <section class="related-section">
        <h2>相关文章</h2>
        <div class="related-grid">
          {relatedPosts.map(({ post: relatedPost, path }) => (
            <div class="related-card">
              <p class="related-category">
                {relatedPost.data.categories
                  .map(category => getCategoryMeta(category)?.name ?? category)
                  .join(" / ")}
              </p>
              <h3 class="related-card-title">
                <a href={path} class="related-card-title-link">
                  {relatedPost.data.title}
                </a>
              </h3>
              <p class="related-card-excerpt">
                {PostUtils.getPlainTextDescription(
                  (relatedPost.data.description?.trim() || relatedPost.body) ??
                    ""
                )}
              </p>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- Previous/Next Post Buttons -->
  <nav class="post-nav" aria-label="文章导航">
    <!-- 上一篇 -->
    {
      prevPost && (
        <a href={prevPost.path} class="nav-link-prev">
          <IconChevronLeft />
          {prevPost.title}
        </a>
      )
    }
    <!-- 下一篇 -->
    {
      nextPost && (
        <a href={nextPost.path} class="nav-link-next">
          {nextPost.title}
          <IconChevronRight />
        </a>
      )
    }
  </nav>

  <!-- 评论容器：与主栏同宽（不用 reading-wrap 窄栏） -->
  {comments && SITE.artalk.enabled && <div id="Comments" />}
</Layout>

<style is:global>
  #article {
    width: 100%;
    min-width: 0;
  }

  #article > header {
    width: 100%;
  }

  /**
   * 正文 + 目录：正文宽度 = 无目录时整段正文的宽度（#article 内容区 100%），不被 flex 压缩。
   * 容器加宽 + 负 margin 占用主栏右侧空间；目录列固定宽度 + sticky。
   */
  .article-main-layout {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .article-main-layout .article-toc {
    display: none;
  }

  @media (min-width: 1024px) {
    .article-main-layout {
      --article-toc-aside-w: 16rem;
      --article-toc-aside-gap: 2rem;

      flex-direction: row;
      align-items: flex-start;
      gap: var(--article-toc-aside-gap);
      box-sizing: border-box;
      width: calc(
        100% + var(--article-toc-aside-w) + var(--article-toc-aside-gap)
      );
      max-width: none;
      margin-right: calc(
        -1 * (var(--article-toc-aside-w) + var(--article-toc-aside-gap))
      );
    }

    /* 100% 相对本 flex 容器：容器宽 = 正文旧宽 + 目录 + gap → 此项 = 正文旧宽，flex-shrink: 0 不压窄 */
    .article-main-layout .post-article-content {
      flex: 0 0
        calc(100% - var(--article-toc-aside-w) - var(--article-toc-aside-gap));
      min-width: 0;
    }

    .article-main-layout .article-toc {
      display: block;
      flex: 0 0 var(--article-toc-aside-w);
      position: sticky;
      top: var(--site-header-sticky-offset);
      max-height: min(
        calc(100vh - var(--site-header-sticky-offset) - 1rem),
        85vh
      );
      overflow-y: auto;
      margin: 0;
    }
  }

  .post-article-content {
    min-width: 0;
  }
  #article .post-article-content :where(h2, h3, h4) {
    scroll-margin-top: var(--site-header-sticky-offset);
  }

  .reading-wrap {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  #Comments {
    width: 100%;
    max-width: none;
    margin-left: 0;
    margin-right: 0;
  }

  .reading-content {
    line-height: 1.8;
  }

  .reading-content img {
    border-radius: 8px;
  }

  #article .post-article-content {
    padding-bottom: 1rem;
  }

  .article-header {
    margin-bottom: 1.5rem;
  }

  .article-title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.5rem, 4vw, 2rem);
    text-align: center;
  }

  .article-header .article-title {
    margin-top: 0;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem 0.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-align: center;
  }

  .meta-separator {
    opacity: 0.5;
  }

  .reading-time {
    white-space: nowrap;
  }

  .tags-section {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin: 2rem 0;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .tags-icon {
    flex-shrink: 0;
    color: var(--text-secondary);
    margin-top: 0.2rem;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .action-section {
    display: grid;
    gap: 1.25rem;
    margin: 2.5rem 0;
  }

  @media (min-width: 640px) {
    .action-section {
      grid-template-columns: 1fr 1fr;
    }
  }

  .action-card {
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--background-secondary);
  }

  .action-label {
    margin: 0 0 0.35rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent);
  }

  .action-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
  }

  .action-description {
    margin: 0 0 1rem;
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .action-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 8px;
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
    color: white;
  }

  .btn-secondary {
    background: transparent;
    color: var(--accent);
    border-color: var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent-dark);
  }

  .related-section {
    margin: 2.5rem 0;
  }

  .related-section h2 {
    margin-bottom: 1rem;
  }

  .related-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    display: block;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .related-card:has(.related-card-title-link:hover),
  .related-card:has(.related-card-title-link:focus-visible) {
    border-color: var(--accent);
    box-shadow: 0 4px 14px color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .related-category {
    margin: 0 0 0.35rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .related-card-title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .related-card-title-link {
    color: var(--accent);
    text-decoration: none;
  }

  .related-card-title-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .related-card-excerpt {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-nav {
    display: grid;
    gap: 1rem;
    margin: 2rem 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  @media (min-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr 1fr;
    }
  }

  .nav-link-prev,
  .nav-link-next {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: var(--accent);
    font-size: 0.9375rem;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .nav-link-prev:hover,
  .nav-link-next:hover {
    border-color: var(--accent);
    color: var(--accent-dark);
  }

  .nav-link-next {
    justify-content: flex-end;
    text-align: right;
  }
</style>

<!-- Artalk 评论系统 -->
{comments && SITE.artalk.enabled && <Artalk />}

<script is:inline data-astro-rerun>
  function onPageReady() {
    window.scrollTo({ left: 0, top: 0, behavior: "instant" });
  }
  if (window._postDetailsAfterSwapHandler) {
    document.removeEventListener(
      "astro:after-swap",
      window._postDetailsAfterSwapHandler
    );
  }
  window._postDetailsAfterSwapHandler = onPageReady;
  document.addEventListener(
    "astro:after-swap",
    window._postDetailsAfterSwapHandler
  );
  onPageReady();
</script>
