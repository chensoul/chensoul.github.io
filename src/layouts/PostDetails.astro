---
/**
 * 文章详情布局
 *
 * @fileoverview 渲染单篇文章：标题、元数据、正文（Content）、前后篇导航、标签列表，以及按 frontmatter 控制的评论/TOC/数学公式等功能。OG 图与 canonical 由本布局传给 Layout。
 */
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import Artalk from "@/components/Artalk.astro";
import PhotosuiteStyles from "@/components/PhotosuiteStyles.astro";
import { slugifyStr } from "@/utils/slugify";
import { PostUtils } from "@/utils/postUtils";
import { getCategoryMeta } from "@/utils/categoryMeta";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import IconTag from "@/assets/icons/IconTag.svg";
import { SITE } from "@/config";

export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

// 解构文章元数据
const {
  title,
  author,
  canonicalURL,
  date,
  updated,
  tags,
  toc,
  math,
  comments,
  description: postDescription,
  "top-image": topImageRaw,
  categories,
} = post.data;

/** 解析 top-image 的完整 URL：绝对地址原样返回，相对路径在生产环境拼接 CDN 前缀 */
const topImageSrc =
  topImageRaw && topImageRaw.trim()
    ? (() => {
        const src = topImageRaw.trim();
        if (src.startsWith("http://") || src.startsWith("https://")) return src;
        const normalized = src.startsWith("/") ? src : `/${src}`;
        if (import.meta.env.DEV) return normalized;
        const base = (SITE.imageConfig.imagesUrl ?? "")
          .trim()
          .replace(/\/$/, "");
        return base ? `${base}${normalized}` : normalized;
      })()
    : undefined;

// 渲染文章内容
const { Content } = await render(post);
const hasInlineImages = /!\[[\s\S]*?\]\([^)]+\)|<img\s/i.test(post.body ?? "");

// Generate Hugo-style slug for OG image
const year = date.getFullYear();
const month = String(date.getMonth() + 1).padStart(2, "0");
const day = String(date.getDate()).padStart(2, "0");
const slugPart = post.data.slug;
const hugoSlug = `${year}/${month}/${day}/${slugPart}`;
const ogImage = `/og/${hugoSlug}.png`;

/** 文章描述：优先 frontmatter description，否则从正文提取（与 RSS 摘要逻辑一致，不含 top-image） */
const fullDescription =
  postDescription?.trim() || PostUtils.getDescription(post.body ?? "");
const plainText = (post.body ?? "")
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/`[^`]*`/g, " ")
  .replace(/!\[[^\]]*]\([^)]+\)/g, " ")
  .replace(/\[[^\]]*]\([^)]+\)/g, " ")
  .replace(/<[^>]+>/g, " ")
  .replace(/[#>*_\-\n\r]/g, " ")
  .replace(/\s+/g, " ")
  .trim();
const latinWordCount = (
  plainText.match(/[A-Za-z0-9]+(?:['’-][A-Za-z0-9]+)*/g) || []
).length;
const cjkCharCount = (plainText.match(/[\u3400-\u9FFF]/g) || []).length;
const estimatedWordCount = latinWordCount + cjkCharCount;
const readingMinutes = Math.max(1, Math.ceil(estimatedWordCount / 300));
const primaryCategory = categories?.[0];
const primaryCategoryLabel =
  getCategoryMeta(primaryCategory)?.name ?? primaryCategory;
const categoryLinks = categories.map(category => ({
  name: getCategoryMeta(category)?.name ?? category,
  slug: slugifyStr(category),
}));
const breadcrumbItems = [
  { name: "首页", item: SITE.website },
  { name: "文章", item: new URL("/posts", SITE.website).toString() },
  ...(primaryCategory
    ? [
        {
          name: primaryCategoryLabel,
          item: new URL(
            `/categories/${slugifyStr(primaryCategory)}`,
            SITE.website
          ).toString(),
        },
      ]
    : []),
  { name: title, item: canonicalHrefPlaceholder() },
];

function canonicalHrefPlaceholder() {
  return "";
}

const layoutProps = {
  title,
  author,
  description: fullDescription,
  pubDatetime: date,
  modDatetime: updated,
  canonicalURL,
  ogImage,
};

/* ========== Prev/Next Posts ========== */

/**
 * 生成上一篇/下一篇导航
 *
 * 逻辑：
 * 1. 提取所有文章的路径、标题和日期
 * 2. 找到当前文章的索引
 * 3. 获取上一篇（索引-1）和下一篇（索引+1）
 */
const allPosts = posts.map(
  ({ data: { title, date, timezone }, id, filePath }) => ({
    path: PostUtils.getPath(id, filePath, true, date, timezone),
    title,
  })
);

const currentPostPath = PostUtils.getPath(
  post.id,
  post.filePath,
  true,
  post.data.date,
  post.data.timezone
);

const canonicalHref =
  canonicalURL != null
    ? String(canonicalURL)
    : new URL(currentPostPath, SITE.website).toString();
breadcrumbItems[breadcrumbItems.length - 1].item = canonicalHref;
const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.item,
  })),
};

const relatedPostLimit = 6;
const scoredRelatedPosts = posts
  .filter(candidate => candidate.id !== post.id)
  .map(candidate => {
    const sharedTags = candidate.data.tags.filter(tag =>
      tags.includes(tag)
    ).length;
    const sharedCategories = candidate.data.categories.filter(category =>
      post.data.categories.includes(category)
    ).length;
    const score = sharedCategories * 4 + sharedTags * 2;

    return {
      post: candidate,
      score,
      path: PostUtils.getPath(
        candidate.id,
        candidate.filePath,
        true,
        candidate.data.date,
        candidate.data.timezone
      ),
    };
  })
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;

    return (
      new Date(b.post.data.updated ?? b.post.data.date).getTime() -
      new Date(a.post.data.updated ?? a.post.data.date).getTime()
    );
  });

const relatedPosts = [
  ...scoredRelatedPosts.filter(item => item.score > 0),
  ...scoredRelatedPosts.filter(item => item.score === 0),
].slice(0, relatedPostLimit);

const shareText = `${title} | ${SITE.title}`;
const shareUrl = encodeURIComponent(canonicalHref);
const shareTitle = encodeURIComponent(shareText);
const shareDescription = encodeURIComponent(fullDescription);

const currentPostIndex = allPosts.findIndex(a => a.path === currentPostPath);

const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;

/** 预加载样式转正样式用，避免 TS 把 onload 属性内容当代码解析 */
const linkPreloadOnLoad = "this.onload=null;this.rel='stylesheet'";
---

<Layout {...layoutProps}>
  {hasInlineImages && <PhotosuiteStyles />}
  {
    tags.map((tag: string) => (
      <meta slot="head" property="article:tag" content={tag} />
    ))
  }
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbStructuredData)}
  />
  <!-- KaTeX 数学公式样式（仅文章详情且启用公式时加载） -->
  {
    math && (
      <link
        slot="head"
        rel="preload"
        href="https://cos.chensoul.cc/dist/katex/0.16.38/dist/katex.min.css"
        as="style"
        crossorigin="anonymous"
        referrerpolicy="no-referrer"
        onload={linkPreloadOnLoad}
      />
    )
  }
  {
    math && (
      <noscript slot="head">
        <link
          rel="stylesheet"
          href="https://cos.chensoul.cc/dist/katex/0.16.38/dist/katex.min.css"
          crossorigin="anonymous"
          referrerpolicy="no-referrer"
        />
      </noscript>
    )
  }

  <!-- 文章内容（js-toc-content 供 tocbot 扫描 h2/h3/h4 生成目录） -->
  <article id="article" class="js-toc-content" data-pagefind-body>
    <!-- 文章主体上方配图（frontmatter top-image，不参与描述提取） -->
    {topImageSrc && <img src={topImageSrc} alt={title} />}

    <!-- 文章标题与发布日期 -->
    <nav class="post-breadcrumbs" aria-label="面包屑导航">
      <a href="/">首页</a>
      <span>/</span>
      <a href="/posts">文章</a>
      {
        primaryCategory && (
          <>
            <span>/</span>
            <a href={`/categories/${slugifyStr(primaryCategory)}`}>
              {primaryCategoryLabel}
            </a>
          </>
        )
      }
    </nav>

    <section class="mx-auto mt-4 mb-2 w-full max-w-4xl text-center">
      <h1 class="text-2xl font-semibold">{title}</h1>
      <div class="post-meta-strip">
        {
          categoryLinks.map(category => (
            <a class="post-category-chip" href={`/categories/${category.slug}`}>
              {category.name}
            </a>
          ))
        }
        <span class="post-meta-divider" aria-hidden="true">·</span>
        <span>{readingMinutes} 分钟阅读</span>
        <span class="post-meta-divider" aria-hidden="true">·</span>
        <Datetime
          pubDatetime={date}
          modDatetime={updated}
          timezone={post.data.timezone}
          format="absolute"
          class="inline-flex text-sm text-[var(--accent)]"
        />
      </div>
    </section>

    <Content />
  </article>

  <!-- 标签列表 -->
  {
    tags.length > 0 && (
      <div class="post-tags-row mt-8 mb-4 flex flex-wrap items-center gap-x-2 gap-y-1.5">
        <span
          class="post-tags-icon flex shrink-0 items-center"
          aria-hidden="true"
        >
          <IconTag class="h-4 w-4 text-[var(--text-secondary)]" />
        </span>
        <ul
          class="post-tags-list flex flex-wrap items-center gap-2"
          role="list"
        >
          {tags.map((tag: string) => (
            <Tag tag={slugifyStr(tag)} tagName={tag} />
          ))}
        </ul>
      </div>
    )
  }

  <section class="post-promo-grid mt-10 grid gap-4">
    <div class="post-promo-card">
      <p class="post-promo-eyebrow">订阅文章</p>
      <h2 class="post-promo-title">订阅更新，不错过后续文章</h2>
      <p class="post-promo-copy">直接通过 RSS 和 Telegram 订阅本站更新。</p>
      <div class="post-promo-actions">
        <a class="post-promo-button primary" href="/rss.xml">订阅 RSS</a>
        <a class="post-promo-button" href="https://t.me/ichensoul"
          >关注 Telegram</a
        >
      </div>
    </div>

    <div class="post-promo-card">
      <p class="post-promo-eyebrow">分享文章</p>
      <h2 class="post-promo-title">如果这篇有帮助，可以顺手转发</h2>
      <p class="post-promo-copy">
        直接分享给同事、朋友，或者发到你的社交平台。
      </p>
      <div class="post-promo-actions">
        <a
          class="post-promo-button"
          href={`https://x.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          分享到 X
        </a>
        <a
          class="post-promo-button"
          href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          分享到 Telegram
        </a>
        <a
          class="post-promo-button"
          href={`mailto:?subject=${shareTitle}&body=${shareDescription}%0A%0A${shareUrl}`}
        >
          邮件分享
        </a>
      </div>
    </div>
  </section>

  {
    relatedPosts.length > 0 && (
      <section class="related-posts-section mt-10">
        <div class="related-posts-header">
          <h2 class="related-posts-title">相关文章</h2>
        </div>
        <div class="related-posts-grid">
          {relatedPosts.map(({ post: relatedPost, path }) => (
            <a href={path} class="related-post-card">
              <p class="related-post-meta">
                {relatedPost.data.categories
                  .map(category => getCategoryMeta(category)?.name ?? category)
                  .join(" / ")}
              </p>
              <h3>{relatedPost.data.title}</h3>
              <p>
                {relatedPost.data.description?.trim() ||
                  PostUtils.getDescription(relatedPost.body ?? "")}
              </p>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- Previous/Next Post Buttons -->
  <div data-pagefind-ignore class="my-6 grid grid-cols-1 gap-6 sm:grid-cols-2">
    <!-- 上一篇 -->
    {
      prevPost && (
        <a href={prevPost.path} class="flex w-full gap-1 hover:opacity-75">
          <IconChevronLeft class="inline-block flex-none" />
          <div>
            <div class="text-sm text-[var(--accent)] opacity-85">
              {prevPost.title}
            </div>
          </div>
        </a>
      )
    }
    <!-- 下一篇 -->
    {
      nextPost && (
        <a
          href={nextPost.path}
          class="flex w-full justify-end gap-1 text-right hover:opacity-75 sm:col-start-2"
        >
          <div>
            <div class="text-sm text-[var(--accent)] opacity-85">
              {nextPost.title}
            </div>
          </div>
          <IconChevronRight class="inline-block flex-none" />
        </a>
      )
    }
  </div>

  <!-- 评论容器 -->
  <div id="Comments"></div>

  <!-- 侧边栏：文章目录（与 astro-lhasa 一致，内联实现） -->
  <aside
    id="sidebar"
    class:list={["sidebar", "hidden lg:block", { "no-toc": !toc }]}
  >
    {toc && <div id="toc-container" class="js-toc" />}
    <div
      class="flex flex-col items-start space-y-0 truncate overflow-hidden whitespace-nowrap opacity-80"
    >
    </div>
  </aside>
</Layout>

<!-- 侧栏与 TOC 样式（tocbot 注入的 .toc 等类） -->
<style>
  .post-breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .post-breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .post-breadcrumbs a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .post-meta-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .post-category-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background: var(--background-secondary);
    color: var(--text-secondary);
    text-decoration: none;
  }

  .post-category-chip:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .post-meta-divider {
    color: var(--border);
  }

  #article :global(h2[id]),
  #article :global(h3[id]),
  #article :global(h4[id]),
  #article :global(h5[id]),
  #article :global(h6[id]) {
    /* 锚点跳转时预留 sticky header 高度，避免标题被遮挡 */
    scroll-margin-top: 5rem;
  }

  @media (min-width: 1300px) {
    #sidebar {
      position: fixed;
      top: 10rem;
      right: 5rem;
      z-index: 40;
      margin: 0;
      max-height: calc(100vh - 8rem);
      width: 14rem;
      transform: translateX(0);
      border: none;
      box-shadow: none;
      border-radius: 0.5rem;
      padding: 1rem 0.75rem;
      background-color: color-mix(
        in srgb,
        var(--text-primary) 2%,
        var(--background)
      );
    }
    :global(.toc > .toc-list) {
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }
    :global(.toc > .toc-list > .toc-list-item) {
      margin-top: 0;
      margin-bottom: 0.75rem;
    }
    :global(.toc > .toc-list > .toc-list-item:last-child) {
      margin-bottom: 0;
    }
    :global(.toc > .toc-list > .toc-list-item > .toc-list) {
      margin-top: 0.25rem;
      margin-bottom: 0;
      padding-left: 0.75rem;
    }
    :global(.toc-list) {
      margin: 0;
      padding: 0;
      list-style: none;
    }
    :global(.toc-list-item) {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      color: var(--text-primary);
      margin-top: 0.25rem;
      margin-bottom: 0.25rem;
    }
    :global(.toc-list .toc-list .toc-list-item) {
      margin-top: 0.125rem;
      margin-bottom: 0.125rem;
    }
    :global(.toc-link) {
      font-size: 0.875rem;
      color: var(--text-primary);
      display: block;
      padding-top: 0.25rem;
      padding-bottom: 0.25rem;
      line-height: 1.5;
    }
    :global(.toc-link.is-active-link) {
      color: var(--accent);
    }
    :global(.toc-link::before) {
      display: none !important;
      content: "";
    }
  }
  @media (min-width: 1600px) {
    #sidebar {
      width: 16rem;
    }
  }

  /* 标签行：图标与标签胶囊同一水平线 */
  .post-tags-row {
    align-items: center;
  }
  .post-tags-icon {
    display: flex;
    align-items: center;
    line-height: 0;
  }
  .post-tags-icon :global(svg) {
    display: block;
    vertical-align: middle;
  }
  .post-tags-list {
    list-style: none;
    padding-left: 0;
    margin: 0;
    align-items: center;
  }

  .post-promo-grid {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .post-promo-card,
  .related-post-card {
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1.25rem;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent) 7%, var(--background)),
      var(--background)
    );
  }

  .post-promo-eyebrow,
  .related-posts-eyebrow,
  .related-post-meta {
    margin: 0 0 0.5rem;
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .post-promo-title,
  .related-posts-title {
    margin: 0;
    font-size: 1rem;
  }

  .post-promo-copy {
    margin: 0.75rem 0 0;
    color: var(--text-secondary);
  }

  .post-promo-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .post-promo-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.95rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.8125rem;
    color: var(--text-primary);
    background: var(--background);
    text-decoration: none;
  }

  .post-promo-button:hover {
    text-decoration: none;
    border-color: var(--accent);
    color: var(--accent);
  }

  .post-promo-button.primary {
    border-color: var(--accent);
    background: var(--accent);
    color: white;
  }

  .related-posts-section {
    display: grid;
    gap: 1rem;
  }

  .related-posts-grid {
    display: grid;
    gap: 1rem;
  }

  .related-post-card {
    display: block;
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .related-post-card:hover {
    text-decoration: none;
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .related-post-card h3 {
    margin: 0;
    font-size: 1rem;
  }

  .related-post-card p:last-child {
    margin: 0.75rem 0 0;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  @media (min-width: 768px) {
    .post-promo-grid,
    .related-posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .related-posts-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>

<!-- Artalk 评论系统 -->
{comments && <Artalk />}

<script
  is:inline
  data-astro-rerun
  define:vars={{
    tocbotJsUrl: SITE.tocbot.jsUrl,
    tocbotCssUrl: SITE.tocbot.cssUrl,
  }}
>
  /* Tocbot：空闲时按需注入 CSS/JS，再初始化目录 */
  (function () {
    if (!document.getElementById("toc-container")) return;
    const headingOffset = 80;
    const scrollSmoothOffset = -headingOffset;
    function ensureTocbotCSS() {
      if (!tocbotCssUrl) return;
      const selector = 'link[href="' + tocbotCssUrl + '"]';
      if (document.querySelector(selector)) return;

      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = tocbotCssUrl;
      link.crossOrigin = "anonymous";
      link.referrerPolicy = "no-referrer";
      document.head.appendChild(link);
    }
    function initTocbot() {
      if (typeof window !== "undefined" && window.tocbot) {
        window.tocbot.init({
          tocSelector: ".js-toc",
          contentSelector: ".js-toc-content",
          headingSelector: "h2, h3, h4",
          hasInnerContainers: true,
          headingsOffset: headingOffset,
          scrollSmoothDuration: 300,
          scrollSmoothOffset,
        });
      }
    }
    function loadTocbot() {
      ensureTocbotCSS();
      if (window.tocbot) {
        initTocbot();
      } else if (tocbotJsUrl) {
        const script = document.createElement("script");
        script.src = tocbotJsUrl;
        script.crossOrigin = "anonymous";
        script.referrerPolicy = "no-referrer";
        script.onload = initTocbot;
        document.body.appendChild(script);
      }
    }
    if (typeof requestIdleCallback !== "undefined") {
      requestIdleCallback(loadTocbot, { timeout: 2000 });
    } else {
      setTimeout(loadTocbot, 1);
    }
  })();
  function onPageReady() {
    window.scrollTo({ left: 0, top: 0, behavior: "instant" });
  }
  if (window._postDetailsAfterSwapHandler) {
    document.removeEventListener(
      "astro:after-swap",
      window._postDetailsAfterSwapHandler
    );
  }
  window._postDetailsAfterSwapHandler = onPageReady;
  document.addEventListener(
    "astro:after-swap",
    window._postDetailsAfterSwapHandler
  );
  onPageReady();
</script>
